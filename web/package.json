{
  "name": "raytsystem-control-plane",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "licenses:generate": "node scripts/generate-third-party-notices.mjs",
    "licenses:check": "node scripts/generate-third-party-notices.mjs --check",
    "typecheck": "tsc -b --pretty false",
    "browser:install": "playwright install chromium",
    "test": "npm run test:unit && npm run test:graph-worker && npm run test:layout && npm run test:a11y",
    "test:unit": "vitest run",
    "test:graph-worker": "vitest run --config vitest.browser.config.ts src/test/forceLayout.browser.test.tsx",
    "test:layout": "vitest run --config vitest.browser.config.ts src/test/layout.browser.test.tsx",
    "test:a11y": "vitest run --config vitest.browser.config.ts src/test/accessibility.browser.test.tsx",
    "test:visual": "vitest run --config vitest.browser.config.ts src/test/visual.browser.test.tsx",
    "test:visual:update": "vitest run --config vitest.browser.config.ts src/test/visual.browser.test.tsx --update",
    "screenshots:github": "vitest run --config vitest.github.config.ts",
    "lint": "eslint . --max-warnings 0"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "6.5.0",
    "@codemirror/lint": "6.9.7",
    "@fontsource-variable/bricolage-grotesque": "5.2.10",
    "@fontsource-variable/ibm-plex-sans": "5.2.8",
    "@fontsource/ibm-plex-mono": "5.2.7",
    "@milkdown/kit": "7.21.2",
    "@tanstack/react-query": "5.101.2",
    "codemirror": "6.0.2",
    "graphology": "0.26.0",
    "graphology-layout-forceatlas2": "0.10.1",
    "lucide-react": "1.24.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sigma": "3.0.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/browser-playwright": "4.1.10",
    "axe-core": "^4.12.1",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "jsdom": "29.1.1",
    "playwright": "1.61.1",
    "typescript": "7.0.2",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
