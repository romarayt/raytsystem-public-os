{
  "name": "raytsystem-knowledge-base",
  "version": "0.1.0",
  "private": true,
  "description": "raytsystem public knowledge base (Docusaurus site)",
  "license": "Apache-2.0",
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "build": "docusaurus build",
    "serve": "docusaurus serve",
    "clear": "docusaurus clear",
    "swizzle": "docusaurus swizzle",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc",
    "gen:reference": "uv run --project .. python ../scripts/docs/gen_reference.py --write",
    "check:reference": "uv run --project .. python ../scripts/docs/gen_reference.py --check",
    "check:coverage": "uv run --project .. python ../scripts/docs/coverage_check.py",
    "check:frontmatter": "uv run --project .. python ../scripts/docs/frontmatter_lint.py"
  },
  "dependencies": {
    "@docusaurus/core": "3.10.2",
    "@docusaurus/preset-classic": "3.10.2",
    "@easyops-cn/docusaurus-search-local": "^0.55.2",
    "@mdx-js/react": "^3.0.0",
    "clsx": "^2.1.1",
    "prism-react-renderer": "^2.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.2",
    "@docusaurus/tsconfig": "3.10.2",
    "@docusaurus/types": "3.10.2",
    "typescript": "~5.6.2"
  },
  "overrides": {
    "serialize-javascript": "7.0.5",
    "uuid": "11.1.1"
  },
  "browserslist": {
    "production": [">0.5%", "not dead", "not op_mini all"],
    "development": ["last 3 chrome version", "last 3 firefox version", "last 5 safari version"]
  },
  "engines": {
    "node": ">=22.0"
  }
}
