{
  "$defs": {
    "Artifact": {
      "additionalProperties": false,
      "properties": {
        "approval_ids": {
          "default": [],
          "items": {
            "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
            "type": "string"
          },
          "title": "Approval Ids",
          "type": "array"
        },
        "artifact_id": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Artifact Id",
          "type": "string"
        },
        "claim_ids": {
          "default": [],
          "items": {
            "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
            "type": "string"
          },
          "title": "Claim Ids",
          "type": "array"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "extensions": {
          "additionalProperties": true,
          "title": "Extensions",
          "type": "object"
        },
        "feedback_ids": {
          "default": [],
          "items": {
            "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
            "type": "string"
          },
          "title": "Feedback Ids",
          "type": "array"
        },
        "id_scheme_version": {
          "default": "1",
          "title": "Id Scheme Version",
          "type": "string"
        },
        "input_refs": {
          "default": [],
          "items": {
            "$ref": "#/$defs/RecordRef"
          },
          "title": "Input Refs",
          "type": "array"
        },
        "kind": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Kind",
          "type": "string"
        },
        "model_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ComponentRef"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "output_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Output Sha256",
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "title": "Path",
          "type": "string"
        },
        "project_id": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Project Id",
          "type": "string"
        },
        "prompt_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ComponentRef"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "run_id": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Run Id",
          "type": "string"
        },
        "schema_name": {
          "const": "ArtifactV1",
          "default": "ArtifactV1",
          "title": "Schema Name",
          "type": "string"
        },
        "schema_version": {
          "default": "1.2.0",
          "title": "Schema Version",
          "type": "string"
        },
        "skill_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ComponentRef"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "stage_id": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Stage Id",
          "type": "string"
        },
        "state": {
          "$ref": "#/$defs/ArtifactState",
          "default": "draft"
        }
      },
      "required": [
        "artifact_id",
        "kind",
        "project_id",
        "stage_id",
        "run_id",
        "output_sha256",
        "path",
        "created_at"
      ],
      "title": "Artifact",
      "type": "object"
    },
    "ArtifactState": {
      "enum": [
        "draft",
        "validated",
        "awaiting_review",
        "ready",
        "superseded",
        "archived"
      ],
      "title": "ArtifactState",
      "type": "string"
    },
    "ComponentRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Artifact Sha256"
        },
        "config_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Config Sha256",
          "type": "string"
        },
        "name": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Name",
          "type": "string"
        },
        "version": {
          "maxLength": 4096,
          "minLength": 1,
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "name",
        "version",
        "config_sha256"
      ],
      "title": "ComponentRef",
      "type": "object"
    },
    "RecordRef": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Kind",
          "type": "string"
        },
        "object_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Object Sha256",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "id",
        "object_sha256"
      ],
      "title": "RecordRef",
      "type": "object"
    },
    "YouTubeStage": {
      "enum": [
        "brief",
        "verdict",
        "research",
        "titles",
        "thumbnails",
        "script",
        "presentation",
        "packaging",
        "warmup",
        "master",
        "review"
      ],
      "title": "YouTubeStage",
      "type": "string"
    },
    "YouTubeStageDependency": {
      "additionalProperties": false,
      "properties": {
        "output_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Output Sha256",
          "type": "string"
        },
        "stage": {
          "$ref": "#/$defs/YouTubeStage"
        }
      },
      "required": [
        "stage",
        "output_sha256"
      ],
      "title": "YouTubeStageDependency",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "artifact": {
      "$ref": "#/$defs/Artifact"
    },
    "completed_at": {
      "format": "date-time",
      "title": "Completed At",
      "type": "string"
    },
    "dependencies": {
      "default": [],
      "items": {
        "$ref": "#/$defs/YouTubeStageDependency"
      },
      "title": "Dependencies",
      "type": "array"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "external_input_sha256": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "External Input Sha256"
    },
    "fingerprint_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Fingerprint Sha256",
      "type": "string"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "output_path": {
      "minLength": 1,
      "title": "Output Path",
      "type": "string"
    },
    "output_schema_name": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Output Schema Name",
      "type": "string"
    },
    "output_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Output Sha256",
      "type": "string"
    },
    "pipeline_version": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Pipeline Version",
      "type": "string"
    },
    "project_id": {
      "pattern": "^ytp_[a-z0-9_]{2,120}$",
      "title": "Project Id",
      "type": "string"
    },
    "run_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Run Id",
      "type": "string"
    },
    "schema_name": {
      "const": "YouTubeStageRecordV1",
      "default": "YouTubeStageRecordV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.2.0",
      "title": "Schema Version",
      "type": "string"
    },
    "stage": {
      "$ref": "#/$defs/YouTubeStage"
    },
    "stage_record_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Stage Record Id",
      "type": "string"
    },
    "status": {
      "const": "succeeded",
      "default": "succeeded",
      "title": "Status",
      "type": "string"
    }
  },
  "required": [
    "stage_record_id",
    "project_id",
    "run_id",
    "stage",
    "fingerprint_sha256",
    "output_schema_name",
    "output_sha256",
    "output_path",
    "artifact",
    "pipeline_version",
    "completed_at"
  ],
  "title": "YouTubeStageRecord",
  "type": "object"
}
