{
  "$defs": {
    "YouTubeLineKind": {
      "enum": [
        "factual",
        "inference",
        "editorial"
      ],
      "title": "YouTubeLineKind",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "fact_ids": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Fact Ids",
      "type": "array"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "line_kind": {
      "$ref": "#/$defs/YouTubeLineKind"
    },
    "needs_review": {
      "default": true,
      "title": "Needs Review",
      "type": "boolean"
    },
    "project_id": {
      "pattern": "^ytp_[a-z0-9_]{2,120}$",
      "title": "Project Id",
      "type": "string"
    },
    "schema_name": {
      "const": "YouTubeWarmupV1",
      "default": "YouTubeWarmupV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.2.0",
      "title": "Schema Version",
      "type": "string"
    },
    "state": {
      "const": "draft",
      "default": "draft",
      "title": "State",
      "type": "string"
    },
    "text": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Text",
      "type": "string"
    },
    "warmup_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Warmup Id",
      "type": "string"
    }
  },
  "required": [
    "warmup_id",
    "project_id",
    "text",
    "line_kind"
  ],
  "title": "YouTubeWarmup",
  "type": "object"
}
