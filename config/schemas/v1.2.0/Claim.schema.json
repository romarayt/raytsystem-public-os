{
  "$defs": {
    "ClaimStatus": {
      "enum": [
        "supported",
        "confirmed",
        "disputed",
        "stale",
        "superseded",
        "retracted"
      ],
      "title": "ClaimStatus",
      "type": "string"
    },
    "TimeRange": {
      "additionalProperties": false,
      "properties": {
        "invalid_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Invalid At"
        },
        "valid_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Valid At"
        }
      },
      "title": "TimeRange",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "claim_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Claim Id",
      "type": "string"
    },
    "confidence_components": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Confidence Components",
      "type": "object"
    },
    "contradicts": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Contradicts",
      "type": "array"
    },
    "evidence_ids": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Evidence Ids",
      "type": "array"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "language": {
      "default": "und",
      "title": "Language",
      "type": "string"
    },
    "proposition_key": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Proposition Key"
    },
    "recorded_at": {
      "format": "date-time",
      "title": "Recorded At",
      "type": "string"
    },
    "relation_ids": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Relation Ids",
      "type": "array"
    },
    "review_ids": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Review Ids",
      "type": "array"
    },
    "schema_name": {
      "const": "ClaimV1",
      "default": "ClaimV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.2.0",
      "title": "Schema Version",
      "type": "string"
    },
    "scope": {
      "additionalProperties": true,
      "title": "Scope",
      "type": "object"
    },
    "statement": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Statement",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/ClaimStatus"
    },
    "supersedes": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Supersedes",
      "type": "array"
    },
    "temporal": {
      "$ref": "#/$defs/TimeRange"
    }
  },
  "required": [
    "claim_id",
    "statement",
    "status",
    "recorded_at"
  ],
  "title": "Claim",
  "type": "object"
}
