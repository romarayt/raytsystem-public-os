{
  "additionalProperties": false,
  "properties": {
    "brief_input_path": {
      "minLength": 1,
      "title": "Brief Input Path",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "master_path": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Master Path"
    },
    "project_id": {
      "pattern": "^ytp_[a-z0-9_]{2,120}$",
      "title": "Project Id",
      "type": "string"
    },
    "research_input_path": {
      "minLength": 1,
      "title": "Research Input Path",
      "type": "string"
    },
    "run_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Run Id",
      "type": "string"
    },
    "schema_name": {
      "const": "YouTubeProjectManifestV1",
      "default": "YouTubeProjectManifestV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.2.0",
      "title": "Schema Version",
      "type": "string"
    },
    "stage_record_sha256": {
      "additionalProperties": {
        "pattern": "^[0-9a-f]{64}$",
        "type": "string"
      },
      "title": "Stage Record Sha256",
      "type": "object"
    },
    "status": {
      "enum": [
        "running",
        "checkpointed",
        "draft_complete",
        "failed"
      ],
      "title": "Status",
      "type": "string"
    },
    "synthetic_fixture": {
      "const": true,
      "default": true,
      "title": "Synthetic Fixture",
      "type": "boolean"
    },
    "updated_at": {
      "format": "date-time",
      "title": "Updated At",
      "type": "string"
    }
  },
  "required": [
    "project_id",
    "run_id",
    "brief_input_path",
    "research_input_path",
    "stage_record_sha256",
    "status",
    "updated_at"
  ],
  "title": "YouTubeProjectManifest",
  "type": "object"
}
