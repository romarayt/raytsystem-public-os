{
  "$defs": {
    "CitationVerification": {
      "enum": [
        "verified",
        "failed",
        "pending"
      ],
      "title": "CitationVerification",
      "type": "string"
    },
    "RecordRef": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Kind",
          "type": "string"
        },
        "object_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Object Sha256",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "id",
        "object_sha256"
      ],
      "title": "RecordRef",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "answer_char_end": {
      "minimum": 0,
      "title": "Answer Char End",
      "type": "integer"
    },
    "answer_char_start": {
      "minimum": 0,
      "title": "Answer Char Start",
      "type": "integer"
    },
    "answer_proposal_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Answer Proposal Id",
      "type": "string"
    },
    "cited_excerpt_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Cited Excerpt Sha256",
      "type": "string"
    },
    "claim_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Claim Id"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "failure_codes": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Failure Codes",
      "type": "array"
    },
    "generation_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Generation Id",
      "type": "string"
    },
    "generation_ref": {
      "$ref": "#/$defs/RecordRef"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "normalization_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Normalization Id",
      "type": "string"
    },
    "query_citation_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Query Citation Id",
      "type": "string"
    },
    "schema_name": {
      "const": "QueryCitationV1",
      "default": "QueryCitationV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.2.0",
      "title": "Schema Version",
      "type": "string"
    },
    "segment_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Segment Id",
      "type": "string"
    },
    "source_locator": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Source Locator",
      "type": "string"
    },
    "source_revision_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Source Revision Id",
      "type": "string"
    },
    "verification": {
      "$ref": "#/$defs/CitationVerification",
      "default": "pending"
    },
    "verified_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Verified At"
    }
  },
  "required": [
    "query_citation_id",
    "answer_proposal_id",
    "generation_id",
    "generation_ref",
    "answer_char_start",
    "answer_char_end",
    "source_revision_id",
    "normalization_id",
    "segment_id",
    "cited_excerpt_sha256",
    "source_locator"
  ],
  "title": "QueryCitation",
  "type": "object"
}
