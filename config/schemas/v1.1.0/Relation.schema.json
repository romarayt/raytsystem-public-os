{
  "$defs": {
    "EntityObject": {
      "additionalProperties": false,
      "properties": {
        "entity_id": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Entity Id",
          "type": "string"
        },
        "extensions": {
          "additionalProperties": true,
          "title": "Extensions",
          "type": "object"
        },
        "id_scheme_version": {
          "default": "1",
          "title": "Id Scheme Version",
          "type": "string"
        },
        "kind": {
          "const": "entity",
          "default": "entity",
          "title": "Kind",
          "type": "string"
        },
        "schema_name": {
          "const": "EntityObjectV1",
          "default": "EntityObjectV1",
          "title": "Schema Name",
          "type": "string"
        },
        "schema_version": {
          "default": "1.1.0",
          "title": "Schema Version",
          "type": "string"
        }
      },
      "required": [
        "entity_id"
      ],
      "title": "EntityObject",
      "type": "object"
    },
    "LifecycleStatus": {
      "enum": [
        "active",
        "disputed",
        "stale",
        "superseded",
        "retracted"
      ],
      "title": "LifecycleStatus",
      "type": "string"
    },
    "LiteralObject": {
      "additionalProperties": false,
      "properties": {
        "datatype": {
          "default": "text",
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Datatype",
          "type": "string"
        },
        "extensions": {
          "additionalProperties": true,
          "title": "Extensions",
          "type": "object"
        },
        "id_scheme_version": {
          "default": "1",
          "title": "Id Scheme Version",
          "type": "string"
        },
        "kind": {
          "const": "literal",
          "default": "literal",
          "title": "Kind",
          "type": "string"
        },
        "language": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Language"
        },
        "schema_name": {
          "const": "LiteralObjectV1",
          "default": "LiteralObjectV1",
          "title": "Schema Name",
          "type": "string"
        },
        "schema_version": {
          "default": "1.1.0",
          "title": "Schema Version",
          "type": "string"
        },
        "value": {
          "maxLength": 4096,
          "minLength": 1,
          "title": "Value",
          "type": "string"
        }
      },
      "required": [
        "value"
      ],
      "title": "LiteralObject",
      "type": "object"
    },
    "TimeRange": {
      "additionalProperties": false,
      "properties": {
        "invalid_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Invalid At"
        },
        "valid_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Valid At"
        }
      },
      "title": "TimeRange",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "claim_ids": {
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "minItems": 1,
      "title": "Claim Ids",
      "type": "array"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "lifecycle_status": {
      "$ref": "#/$defs/LifecycleStatus",
      "default": "active"
    },
    "object": {
      "discriminator": {
        "mapping": {
          "entity": "#/$defs/EntityObject",
          "literal": "#/$defs/LiteralObject"
        },
        "propertyName": "kind"
      },
      "oneOf": [
        {
          "$ref": "#/$defs/EntityObject"
        },
        {
          "$ref": "#/$defs/LiteralObject"
        }
      ],
      "title": "Object"
    },
    "predicate": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Predicate",
      "type": "string"
    },
    "qualifiers": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Qualifiers",
      "type": "object"
    },
    "relation_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Relation Id",
      "type": "string"
    },
    "schema_name": {
      "const": "RelationV1",
      "default": "RelationV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "subject_entity_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Subject Entity Id",
      "type": "string"
    },
    "temporal": {
      "$ref": "#/$defs/TimeRange"
    }
  },
  "required": [
    "relation_id",
    "subject_entity_id",
    "predicate",
    "object",
    "claim_ids"
  ],
  "title": "Relation",
  "type": "object"
}
