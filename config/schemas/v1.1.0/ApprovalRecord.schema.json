{
  "$defs": {
    "ApprovalDecision": {
      "enum": [
        "approve",
        "deny"
      ],
      "title": "ApprovalDecision",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "action": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Action",
      "type": "string"
    },
    "approval_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Approval Id",
      "type": "string"
    },
    "approved_at": {
      "format": "date-time",
      "title": "Approved At",
      "type": "string"
    },
    "approver": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Approver",
      "type": "string"
    },
    "artifact_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Artifact Sha256",
      "type": "string"
    },
    "conditions": {
      "default": [],
      "items": {
        "maxLength": 4096,
        "minLength": 1,
        "type": "string"
      },
      "title": "Conditions",
      "type": "array"
    },
    "decision": {
      "$ref": "#/$defs/ApprovalDecision",
      "default": "approve"
    },
    "destination": {
      "anyOf": [
        {
          "maxLength": 4096,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Destination"
    },
    "expires_at": {
      "format": "date-time",
      "title": "Expires At",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "policy_sha256": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Policy Sha256"
    },
    "policy_version": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Policy Version",
      "type": "string"
    },
    "schema_name": {
      "const": "ApprovalRecordV1",
      "default": "ApprovalRecordV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "scope": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Scope",
      "type": "array"
    },
    "target_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Target Id",
      "type": "string"
    }
  },
  "required": [
    "approval_id",
    "action",
    "target_id",
    "artifact_sha256",
    "policy_version",
    "approver",
    "approved_at",
    "expires_at"
  ],
  "title": "ApprovalRecord",
  "type": "object"
}
