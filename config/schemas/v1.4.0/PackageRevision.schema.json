{
  "$defs": {
    "PackageLifecycleState": {
      "enum": [
        "discovered",
        "inspected",
        "quarantined",
        "validated",
        "evaluated",
        "approved",
        "installed",
        "active",
        "superseded",
        "rolled_back",
        "blocked"
      ],
      "title": "PackageLifecycleState",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "activated_by": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Activated By"
    },
    "approval_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Approval Id"
    },
    "content_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Content Sha256",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "eval_run_ids": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Eval Run Ids",
      "type": "array"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "manifest_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Manifest Sha256",
      "type": "string"
    },
    "package_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Package Id",
      "type": "string"
    },
    "previous_revision_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Previous Revision Id"
    },
    "revision_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Revision Id",
      "type": "string"
    },
    "schema_name": {
      "const": "PackageRevisionV1",
      "default": "PackageRevisionV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "state": {
      "$ref": "#/$defs/PackageLifecycleState"
    },
    "validation_report_sha256": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Validation Report Sha256"
    }
  },
  "required": [
    "revision_id",
    "package_id",
    "manifest_sha256",
    "content_sha256",
    "state",
    "created_at"
  ],
  "title": "PackageRevision",
  "type": "object"
}
