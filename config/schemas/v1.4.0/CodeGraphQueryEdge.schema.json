{
  "$defs": {
    "CodeRelation": {
      "enum": [
        "contains",
        "defines",
        "imports",
        "calls",
        "inherits",
        "implements",
        "references",
        "depends_on",
        "configured_by",
        "tests",
        "explained_by",
        "implemented_by",
        "explains",
        "verifies",
        "changed",
        "touches",
        "operates_on"
      ],
      "title": "CodeRelation",
      "type": "string"
    },
    "EdgeConfidence": {
      "enum": [
        "EXTRACTED",
        "INFERRED",
        "AMBIGUOUS"
      ],
      "title": "EdgeConfidence",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Compact context slice of one CodeEdge.\n\nSource file, location and extractor provenance stay on the snapshot edge and\nremain addressable through the stable ``edge_id``.",
  "properties": {
    "confidence": {
      "$ref": "#/$defs/EdgeConfidence"
    },
    "edge_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Edge Id",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "relation": {
      "$ref": "#/$defs/CodeRelation"
    },
    "schema_name": {
      "const": "GraphQueryEdgeV1",
      "default": "GraphQueryEdgeV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "source": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Source",
      "type": "string"
    },
    "target": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Target",
      "type": "string"
    }
  },
  "required": [
    "edge_id",
    "source",
    "target",
    "relation",
    "confidence"
  ],
  "title": "CodeGraphQueryEdge",
  "type": "object"
}
