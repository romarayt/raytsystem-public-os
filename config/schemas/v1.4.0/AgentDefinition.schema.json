{
  "additionalProperties": false,
  "properties": {
    "accent": {
      "pattern": "^#[0-9A-Fa-f]{6}$",
      "title": "Accent",
      "type": "string"
    },
    "agent_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Agent Id",
      "type": "string"
    },
    "approved_data_classes": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Approved Data Classes",
      "type": "array"
    },
    "capabilities": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Capabilities",
      "type": "array"
    },
    "context_paths": {
      "default": [],
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "Context Paths",
      "type": "array"
    },
    "description": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Description",
      "type": "string"
    },
    "egress_destination": {
      "anyOf": [
        {
          "maxLength": 4096,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Egress Destination"
    },
    "enabled": {
      "default": false,
      "title": "Enabled",
      "type": "boolean"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "name": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Name",
      "type": "string"
    },
    "pack_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Pack Id",
      "type": "string"
    },
    "requested_filesystem_mode": {
      "default": "none",
      "enum": [
        "none",
        "read_only",
        "staging_only"
      ],
      "title": "Requested Filesystem Mode",
      "type": "string"
    },
    "role": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Role",
      "type": "string"
    },
    "runtime_adapter_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Runtime Adapter Id",
      "type": "string"
    },
    "schema_name": {
      "const": "AgentDefinitionV1",
      "default": "AgentDefinitionV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "skill_ids": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Skill Ids",
      "type": "array"
    },
    "version": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Version",
      "type": "string"
    }
  },
  "required": [
    "agent_id",
    "name",
    "role",
    "description",
    "version",
    "pack_id",
    "runtime_adapter_id",
    "accent"
  ],
  "title": "AgentDefinition",
  "type": "object"
}
