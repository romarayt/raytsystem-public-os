{
  "additionalProperties": false,
  "properties": {
    "connection_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Connection Id",
      "type": "string"
    },
    "ended_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Ended At"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "schema_name": {
      "const": "McpConnectionV1",
      "default": "McpConnectionV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "server_revision_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Server Revision Id",
      "type": "string"
    },
    "session_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Session Id",
      "type": "string"
    },
    "started_at": {
      "format": "date-time",
      "title": "Started At",
      "type": "string"
    },
    "state": {
      "enum": [
        "opening",
        "ready",
        "closed",
        "failed"
      ],
      "title": "State",
      "type": "string"
    }
  },
  "required": [
    "connection_id",
    "server_revision_id",
    "session_id",
    "state",
    "started_at"
  ],
  "title": "McpConnection",
  "type": "object"
}
