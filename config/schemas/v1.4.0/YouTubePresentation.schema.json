{
  "$defs": {
    "YouTubeLineKind": {
      "enum": [
        "factual",
        "inference",
        "editorial"
      ],
      "title": "YouTubeLineKind",
      "type": "string"
    },
    "YouTubeSlide": {
      "additionalProperties": false,
      "properties": {
        "animation": {
          "maxLength": 4096,
          "minLength": 1,
          "title": "Animation",
          "type": "string"
        },
        "elements": {
          "items": {
            "maxLength": 4096,
            "minLength": 1,
            "type": "string"
          },
          "minItems": 1,
          "title": "Elements",
          "type": "array"
        },
        "fact_ids": {
          "default": [],
          "items": {
            "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
            "type": "string"
          },
          "title": "Fact Ids",
          "type": "array"
        },
        "graphic_type": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Graphic Type",
          "type": "string"
        },
        "line_kind": {
          "$ref": "#/$defs/YouTubeLineKind"
        },
        "purpose": {
          "maxLength": 4096,
          "minLength": 1,
          "title": "Purpose",
          "type": "string"
        },
        "slide_id": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Slide Id",
          "type": "string"
        },
        "title": {
          "maxLength": 4096,
          "minLength": 1,
          "title": "Title",
          "type": "string"
        }
      },
      "required": [
        "slide_id",
        "title",
        "purpose",
        "graphic_type",
        "elements",
        "animation",
        "line_kind"
      ],
      "title": "YouTubeSlide",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "design_instructions_included": {
      "const": false,
      "default": false,
      "title": "Design Instructions Included",
      "type": "boolean"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "needs_review": {
      "default": true,
      "title": "Needs Review",
      "type": "boolean"
    },
    "presentation_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Presentation Id",
      "type": "string"
    },
    "project_id": {
      "pattern": "^ytp_[a-z0-9_]{2,120}$",
      "title": "Project Id",
      "type": "string"
    },
    "schema_name": {
      "const": "YouTubePresentationV1",
      "default": "YouTubePresentationV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "slides": {
      "items": {
        "$ref": "#/$defs/YouTubeSlide"
      },
      "minItems": 3,
      "title": "Slides",
      "type": "array"
    },
    "state": {
      "const": "draft",
      "default": "draft",
      "title": "State",
      "type": "string"
    }
  },
  "required": [
    "presentation_id",
    "project_id",
    "slides"
  ],
  "title": "YouTubePresentation",
  "type": "object"
}
