{
  "$defs": {
    "NotificationType": {
      "enum": [
        "approval_needed",
        "employee_blocked",
        "budget_exceeded",
        "run_failed",
        "review_ready",
        "eval_regression",
        "stale_graph",
        "ingestion_failed",
        "security_finding",
        "package_update",
        "migration_required"
      ],
      "title": "NotificationType",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "acknowledged_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Acknowledged At"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "deduplication_key": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Deduplication Key",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "message": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Message",
      "type": "string"
    },
    "notification_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Notification Id",
      "type": "string"
    },
    "notification_type": {
      "$ref": "#/$defs/NotificationType"
    },
    "origin_event_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Origin Event Id",
      "type": "string"
    },
    "related_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Related Id",
      "type": "string"
    },
    "related_kind": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Related Kind",
      "type": "string"
    },
    "resolved_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Resolved At"
    },
    "schema_name": {
      "const": "NotificationV1",
      "default": "NotificationV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "severity": {
      "enum": [
        "info",
        "low",
        "medium",
        "high",
        "critical"
      ],
      "title": "Severity",
      "type": "string"
    },
    "state": {
      "default": "unread",
      "enum": [
        "unread",
        "read",
        "acknowledged",
        "resolved"
      ],
      "title": "State",
      "type": "string"
    },
    "title": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Title",
      "type": "string"
    }
  },
  "required": [
    "notification_id",
    "notification_type",
    "severity",
    "title",
    "message",
    "related_kind",
    "related_id",
    "origin_event_id",
    "deduplication_key",
    "created_at"
  ],
  "title": "Notification",
  "type": "object"
}
