{
  "$defs": {
    "YouTubeChannel": {
      "enum": [
        "romarayt",
        "neuropros"
      ],
      "title": "YouTubeChannel",
      "type": "string"
    },
    "YouTubeScriptMode": {
      "enum": [
        "anchor",
        "verbatim"
      ],
      "title": "YouTubeScriptMode",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "angle": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Angle",
      "type": "string"
    },
    "audience": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Audience",
      "type": "string"
    },
    "brief_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Brief Id",
      "type": "string"
    },
    "channel": {
      "$ref": "#/$defs/YouTubeChannel"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "mode": {
      "$ref": "#/$defs/YouTubeScriptMode"
    },
    "needs_review": {
      "default": true,
      "title": "Needs Review",
      "type": "boolean"
    },
    "pain": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Pain",
      "type": "string"
    },
    "project_id": {
      "pattern": "^ytp_[a-z0-9_]{2,120}$",
      "title": "Project Id",
      "type": "string"
    },
    "promised_artifact": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Promised Artifact",
      "type": "string"
    },
    "schema_name": {
      "const": "YouTubeBriefV1",
      "default": "YouTubeBriefV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "synthetic_fixture": {
      "const": true,
      "default": true,
      "title": "Synthetic Fixture",
      "type": "boolean"
    },
    "target_length_minutes": {
      "maximum": 180,
      "minimum": 5,
      "title": "Target Length Minutes",
      "type": "integer"
    },
    "topic": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Topic",
      "type": "string"
    }
  },
  "required": [
    "brief_id",
    "project_id",
    "channel",
    "topic",
    "audience",
    "pain",
    "promised_artifact",
    "angle",
    "target_length_minutes",
    "mode",
    "created_at"
  ],
  "title": "YouTubeBrief",
  "type": "object"
}
