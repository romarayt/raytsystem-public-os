{
  "$defs": {
    "BackupKind": {
      "enum": [
        "private_backup",
        "public_release_export",
        "diagnostic_export",
        "workspace_transfer"
      ],
      "title": "BackupKind",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "backup_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Backup Id",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "encrypted": {
      "default": false,
      "title": "Encrypted",
      "type": "boolean"
    },
    "excluded_paths": {
      "default": [],
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "Excluded Paths",
      "type": "array"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "file_hashes": {
      "additionalProperties": {
        "pattern": "^[0-9a-f]{64}$",
        "type": "string"
      },
      "propertyNames": {
        "minLength": 1
      },
      "title": "File Hashes",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "kind": {
      "$ref": "#/$defs/BackupKind"
    },
    "manifest_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Manifest Sha256",
      "type": "string"
    },
    "raytsystem_version": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Raytsystem Version",
      "type": "string"
    },
    "redaction_report_sha256": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Redaction Report Sha256"
    },
    "restricted_data_included": {
      "default": false,
      "title": "Restricted Data Included",
      "type": "boolean"
    },
    "schema_name": {
      "const": "BackupManifestV1",
      "default": "BackupManifestV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "schema_versions": {
      "patternProperties": {
        "^[a-z][a-z0-9_:.@/-]{1,255}$": {
          "maxLength": 4096,
          "minLength": 1,
          "type": "string"
        }
      },
      "title": "Schema Versions",
      "type": "object"
    }
  },
  "required": [
    "backup_id",
    "kind",
    "raytsystem_version",
    "schema_versions",
    "file_hashes",
    "manifest_sha256",
    "created_at"
  ],
  "title": "BackupManifest",
  "type": "object"
}
