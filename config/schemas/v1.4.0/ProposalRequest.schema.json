{
  "$defs": {
    "ComponentRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Artifact Sha256"
        },
        "config_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Config Sha256",
          "type": "string"
        },
        "name": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Name",
          "type": "string"
        },
        "version": {
          "maxLength": 4096,
          "minLength": 1,
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "name",
        "version",
        "config_sha256"
      ],
      "title": "ComponentRef",
      "type": "object"
    },
    "ProposalPurpose": {
      "enum": [
        "extract_knowledge",
        "answer_query",
        "save_synthesis",
        "review"
      ],
      "title": "ProposalPurpose",
      "type": "string"
    },
    "RecordRef": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Kind",
          "type": "string"
        },
        "object_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Object Sha256",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "id",
        "object_sha256"
      ],
      "title": "RecordRef",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "allowed_evidence_ids": {
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Allowed Evidence Ids",
      "type": "array"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "evidence_pack_ref": {
      "$ref": "#/$defs/RecordRef"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "operation_key": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Operation Key",
      "type": "string"
    },
    "policy_constraints": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Policy Constraints",
      "type": "array"
    },
    "prompt_or_skill_ref": {
      "$ref": "#/$defs/ComponentRef"
    },
    "proposal_request_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Proposal Request Id",
      "type": "string"
    },
    "purpose": {
      "$ref": "#/$defs/ProposalPurpose"
    },
    "run_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Run Id",
      "type": "string"
    },
    "schema_name": {
      "const": "ProposalRequestV1",
      "default": "ProposalRequestV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "target_schema_refs": {
      "items": {
        "$ref": "#/$defs/RecordRef"
      },
      "title": "Target Schema Refs",
      "type": "array"
    }
  },
  "required": [
    "proposal_request_id",
    "run_id",
    "operation_key",
    "purpose",
    "evidence_pack_ref",
    "allowed_evidence_ids",
    "target_schema_refs",
    "prompt_or_skill_ref",
    "created_at"
  ],
  "title": "ProposalRequest",
  "type": "object"
}
