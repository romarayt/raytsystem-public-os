      "type": "string"
    },
    "schema_name": {
      "const": "EvalScoreV1",
      "default": "EvalScoreV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "score_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Score Id",
      "type": "string"
    },
    "unit": {
      "default": "ratio",
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Unit",
      "type": "string"
    },
    "value": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "title": "Value"
    }
