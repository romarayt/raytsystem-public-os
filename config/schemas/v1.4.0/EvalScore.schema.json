        {
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "title": "Maximum"
    },
    "name": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
