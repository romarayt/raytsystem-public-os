{
  "$defs": {
    "RuntimeHealthStatus": {
      "enum": [
        "disabled",
        "available",
        "unavailable",
        "degraded"
      ],
      "title": "RuntimeHealthStatus",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "capabilities": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Capabilities",
      "type": "array"
    },
    "checked_at": {
      "format": "date-time",
      "title": "Checked At",
      "type": "string"
    },
    "executable": {
      "maxLength": 512,
      "title": "Executable",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "reason_code": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Reason Code"
    },
    "runtime_adapter_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Runtime Adapter Id",
      "type": "string"
    },
    "schema_name": {
      "const": "RuntimeHealthV1",
      "default": "RuntimeHealthV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/RuntimeHealthStatus"
    },
    "version": {
      "anyOf": [
        {
          "maxLength": 256,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Version"
    }
  },
  "required": [
    "runtime_adapter_id",
    "status",
    "executable",
    "checked_at"
  ],
  "title": "RuntimeHealth",
  "type": "object"
}
