{
  "additionalProperties": false,
  "properties": {
    "backup_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Backup Id",
      "type": "string"
    },
    "compatibility": {
      "enum": [
        "compatible",
        "migration_required",
        "incompatible"
      ],
      "title": "Compatibility",
      "type": "string"
    },
    "conflicts": {
      "default": [],
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "Conflicts",
      "type": "array"
    },
    "dry_run": {
      "default": true,
      "title": "Dry Run",
      "type": "boolean"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "files_to_restore": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "Files To Restore",
      "type": "array"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "manifest_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Manifest Sha256",
      "type": "string"
    },
    "overwrite_existing": {
      "const": false,
      "default": false,
      "title": "Overwrite Existing",
      "type": "boolean"
    },
    "rebuild_projections": {
      "default": true,
      "title": "Rebuild Projections",
      "type": "boolean"
    },
    "restore_plan_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Restore Plan Id",
      "type": "string"
    },
    "schema_name": {
      "const": "RestorePlanV1",
      "default": "RestorePlanV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "restore_plan_id",
    "backup_id",
    "manifest_sha256",
    "compatibility",
    "files_to_restore"
  ],
  "title": "RestorePlan",
  "type": "object"
}
