{
  "additionalProperties": false,
  "properties": {
    "approval_changes": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Approval Changes",
      "type": "array"
    },
    "artifact_changes": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Artifact Changes",
      "type": "array"
    },
    "assertion_changes": {
      "patternProperties": {
        "^[a-z][a-z0-9_:.@/-]{1,255}$": {
          "enum": [
            "added",
            "removed",
            "changed"
          ],
          "type": "string"
        }
      },
      "title": "Assertion Changes",
      "type": "object"
    },
    "comparison_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Comparison Id",
      "type": "string"
    },
    "cost_delta": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "default": "0",
      "title": "Cost Delta"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "eval_score_deltas": {
      "patternProperties": {
        "^[a-z][a-z0-9_:.@/-]{1,255}$": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ]
        }
      },
      "title": "Eval Score Deltas",
      "type": "object"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "failure_changes": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Failure Changes",
      "type": "array"
    },
    "file_changes": {
      "default": [],
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "File Changes",
      "type": "array"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "latency_delta_ms": {
      "default": 0,
      "title": "Latency Delta Ms",
      "type": "integer"
    },
    "left_run_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Left Run Id",
      "type": "string"
    },
    "result_changed": {
      "title": "Result Changed",
      "type": "boolean"
    },
    "right_run_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Right Run Id",
      "type": "string"
    },
    "schema_name": {
      "const": "RunComparisonV1",
      "default": "RunComparisonV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "test_changes": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Test Changes",
      "type": "array"
    },
    "token_delta": {
      "default": 0,
      "title": "Token Delta",
      "type": "integer"
    },
    "tool_call_changes": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Tool Call Changes",
      "type": "array"
    }
  },
  "required": [
    "comparison_id",
    "left_run_id",
    "right_run_id",
    "result_changed",
    "created_at"
  ],
  "title": "RunComparison",
  "type": "object"
}
