{
  "$defs": {
    "YouTubeFactStatus": {
      "enum": [
        "supported",
        "disputed",
        "unsupported"
      ],
      "title": "YouTubeFactStatus",
      "type": "string"
    },
    "YouTubeResearchSeedFact": {
      "additionalProperties": false,
      "properties": {
        "claim": {
          "maxLength": 4096,
          "minLength": 1,
          "title": "Claim",
          "type": "string"
        },
        "contradicts": {
          "default": [],
          "items": {
            "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
            "type": "string"
          },
          "title": "Contradicts",
          "type": "array"
        },
        "display_value": {
          "anyOf": [
            {
              "maxLength": 4096,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Display Value"
        },
        "fact_id": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Fact Id",
          "type": "string"
        },
        "quote": {
          "maxLength": 4096,
          "minLength": 1,
          "title": "Quote",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/YouTubeFactStatus"
        },
        "tags": {
          "default": [],
          "items": {
            "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
            "type": "string"
          },
          "title": "Tags",
          "type": "array"
        }
      },
      "required": [
        "fact_id",
        "claim",
        "quote",
        "status"
      ],
      "title": "YouTubeResearchSeedFact",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "checked_at": {
      "format": "date-time",
      "title": "Checked At",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "facts": {
      "items": {
        "$ref": "#/$defs/YouTubeResearchSeedFact"
      },
      "minItems": 1,
      "title": "Facts",
      "type": "array"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "project_id": {
      "pattern": "^ytp_[a-z0-9_]{2,120}$",
      "title": "Project Id",
      "type": "string"
    },
    "research_seed_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Research Seed Id",
      "type": "string"
    },
    "schema_name": {
      "const": "YouTubeResearchSeedV1",
      "default": "YouTubeResearchSeedV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "source_path": {
      "minLength": 1,
      "title": "Source Path",
      "type": "string"
    },
    "synthetic_fixture": {
      "const": true,
      "default": true,
      "title": "Synthetic Fixture",
      "type": "boolean"
    }
  },
  "required": [
    "research_seed_id",
    "project_id",
    "source_path",
    "facts",
    "checked_at"
  ],
  "title": "YouTubeResearchSeed",
  "type": "object"
}
