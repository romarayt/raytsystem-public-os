{
  "additionalProperties": false,
  "properties": {
    "actor_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Actor Id",
      "type": "string"
    },
    "aggregate_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Aggregate Id",
      "type": "string"
    },
    "causation_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Causation Id"
    },
    "correlation_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Correlation Id"
    },
    "event_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Event Id",
      "type": "string"
    },
    "event_type": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Event Type",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "payload_schema": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Payload Schema",
      "type": "string"
    },
    "payload_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Payload Sha256",
      "type": "string"
    },
    "previous_event_sha256": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Previous Event Sha256"
    },
    "recorded_at": {
      "format": "date-time",
      "title": "Recorded At",
      "type": "string"
    },
    "schema_name": {
      "const": "AuditEventV1",
      "default": "AuditEventV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "sensitivity": {
      "enum": [
        "public",
        "internal",
        "confidential",
        "restricted",
        "secret"
      ],
      "title": "Sensitivity",
      "type": "string"
    },
    "sequence": {
      "minimum": 1,
      "title": "Sequence",
      "type": "integer"
    },
    "stream_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Stream Id",
      "type": "string"
    }
  },
  "required": [
    "event_id",
    "stream_id",
    "aggregate_id",
    "sequence",
    "event_type",
    "actor_id",
    "payload_schema",
    "payload_sha256",
    "sensitivity",
    "recorded_at"
  ],
  "title": "AuditEvent",
  "type": "object"
}
