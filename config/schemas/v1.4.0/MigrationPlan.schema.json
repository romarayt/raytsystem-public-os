{
  "additionalProperties": false,
  "properties": {
    "backup_required": {
      "default": true,
      "title": "Backup Required",
      "type": "boolean"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "from_version": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "From Version",
      "type": "string"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "migration_ids": {
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Migration Ids",
      "type": "array"
    },
    "migration_plan_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Migration Plan Id",
      "type": "string"
    },
    "plan_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Plan Sha256",
      "type": "string"
    },
    "reversible": {
      "title": "Reversible",
      "type": "boolean"
    },
    "schema_name": {
      "const": "MigrationPlanV1",
      "default": "MigrationPlanV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "to_version": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "To Version",
      "type": "string"
    }
  },
  "required": [
    "migration_plan_id",
    "from_version",
    "to_version",
    "migration_ids",
    "reversible",
    "plan_sha256",
    "created_at"
  ],
  "title": "MigrationPlan",
  "type": "object"
}
