{
  "$defs": {
    "PromotionState": {
      "enum": [
        "prepared",
        "committing",
        "committed",
        "reconciling",
        "completed",
        "aborted"
      ],
      "title": "PromotionState",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "approval_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Approval Id"
    },
    "candidate_manifest_sha256": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Candidate Manifest Sha256"
    },
    "control_epoch": {
      "default": "epoch_initial",
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Control Epoch",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "event_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Event Id",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "global_fencing_token": {
      "exclusiveMinimum": 0,
      "title": "Global Fencing Token",
      "type": "integer"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "next_generation_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Next Generation Id",
      "type": "string"
    },
    "operation_key": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Operation Key",
      "type": "string"
    },
    "output_hashes": {
      "additionalProperties": {
        "pattern": "^[0-9a-f]{64}$",
        "type": "string"
      },
      "title": "Output Hashes",
      "type": "object"
    },
    "parent_generation_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Parent Generation Id",
      "type": "string"
    },
    "partition_fencing_token": {
      "exclusiveMinimum": 0,
      "title": "Partition Fencing Token",
      "type": "integer"
    },
    "partition_key": {
      "default": "ledger:current",
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Partition Key",
      "type": "string"
    },
    "policy_decision_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Policy Decision Id"
    },
    "run_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Run Id",
      "type": "string"
    },
    "schema_name": {
      "const": "PromotionTxnV1",
      "default": "PromotionTxnV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "state": {
      "$ref": "#/$defs/PromotionState"
    },
    "txn_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Txn Id",
      "type": "string"
    },
    "updated_at": {
      "format": "date-time",
      "title": "Updated At",
      "type": "string"
    }
  },
  "required": [
    "txn_id",
    "run_id",
    "operation_key",
    "parent_generation_id",
    "next_generation_id",
    "event_id",
    "partition_fencing_token",
    "global_fencing_token",
    "output_hashes",
    "state",
    "created_at",
    "updated_at"
  ],
  "title": "PromotionTxn",
  "type": "object"
}
