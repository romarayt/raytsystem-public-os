{
  "additionalProperties": false,
  "properties": {
    "configuration_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Configuration Sha256",
      "type": "string"
    },
    "enabled": {
      "default": true,
      "title": "Enabled",
      "type": "boolean"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "kind": {
      "enum": [
        "manual",
        "task_event",
        "schedule",
        "webhook_proposal"
      ],
      "title": "Kind",
      "type": "string"
    },
    "schema_name": {
      "const": "WorkflowTriggerV1",
      "default": "WorkflowTriggerV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "trigger_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Trigger Id",
      "type": "string"
    }
  },
  "required": [
    "trigger_id",
    "kind",
    "configuration_sha256"
  ],
  "title": "WorkflowTrigger",
  "type": "object"
}
