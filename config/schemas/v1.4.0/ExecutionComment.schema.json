{
  "$defs": {
    "CommentKind": {
      "enum": [
        "comment",
        "progress",
        "decision",
        "question",
        "blocked",
        "handoff",
        "review",
        "system"
      ],
      "title": "CommentKind",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "actor": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Actor",
      "type": "string"
    },
    "body": {
      "maxLength": 32768,
      "minLength": 1,
      "title": "Body",
      "type": "string"
    },
    "comment_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Comment Id",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "kind": {
      "$ref": "#/$defs/CommentKind"
    },
    "run_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Run Id"
    },
    "schema_name": {
      "const": "ExecutionCommentV1",
      "default": "ExecutionCommentV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "task_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Task Id",
      "type": "string"
    }
  },
  "required": [
    "comment_id",
    "task_id",
    "kind",
    "actor",
    "body",
    "created_at"
  ],
  "title": "ExecutionComment",
  "type": "object"
}
