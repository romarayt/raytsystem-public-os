{
  "$defs": {
    "McpToolPolicy": {
      "enum": [
        "blocked",
        "catalog_only",
        "read_only",
        "approval_required",
        "enabled"
      ],
      "title": "McpToolPolicy",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "network_allowlist": {
      "default": [],
      "items": {
        "maxLength": 4096,
        "minLength": 1,
        "type": "string"
      },
      "title": "Network Allowlist",
      "type": "array"
    },
    "policy_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Policy Id",
      "type": "string"
    },
    "policy_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Policy Sha256",
      "type": "string"
    },
    "read_roots": {
      "default": [],
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "Read Roots",
      "type": "array"
    },
    "schema_name": {
      "const": "McpPolicyV1",
      "default": "McpPolicyV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "secret_ids": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Secret Ids",
      "type": "array"
    },
    "server_revision_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Server Revision Id",
      "type": "string"
    },
    "tool_policies": {
      "patternProperties": {
        "^[a-z][a-z0-9_:.@/-]{1,255}$": {
          "$ref": "#/$defs/McpToolPolicy"
        }
      },
      "title": "Tool Policies",
      "type": "object"
    },
    "write_roots": {
      "default": [],
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "Write Roots",
      "type": "array"
    }
  },
  "required": [
    "policy_id",
    "server_revision_id",
    "tool_policies",
    "policy_sha256"
  ],
  "title": "McpPolicy",
  "type": "object"
}
