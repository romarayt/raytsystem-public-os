{
  "additionalProperties": false,
  "properties": {
    "completed_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Completed At"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "input_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Input Sha256",
      "type": "string"
    },
    "replay_of_run_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Replay Of Run Id"
    },
    "revision_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Revision Id",
      "type": "string"
    },
    "schema_name": {
      "const": "WorkflowRunV1",
      "default": "WorkflowRunV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "started_at": {
      "format": "date-time",
      "title": "Started At",
      "type": "string"
    },
    "state": {
      "enum": [
        "planned",
        "running",
        "paused",
        "cancelled",
        "succeeded",
        "failed"
      ],
      "title": "State",
      "type": "string"
    },
    "step_run_ids": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Step Run Ids",
      "type": "array"
    },
    "workflow_run_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Workflow Run Id",
      "type": "string"
    }
  },
  "required": [
    "workflow_run_id",
    "revision_id",
    "state",
    "input_sha256",
    "started_at"
  ],
  "title": "WorkflowRun",
  "type": "object"
}
