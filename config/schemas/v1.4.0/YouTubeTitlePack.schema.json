{
  "$defs": {
    "YouTubeLineKind": {
      "enum": [
        "factual",
        "inference",
        "editorial"
      ],
      "title": "YouTubeLineKind",
      "type": "string"
    },
    "YouTubePromise": {
      "enum": [
        "benefit",
        "revelation",
        "result",
        "pain",
        "list",
        "mechanism",
        "intrigue"
      ],
      "title": "YouTubePromise",
      "type": "string"
    },
    "YouTubeTitleCandidate": {
      "additionalProperties": false,
      "properties": {
        "fact_ids": {
          "default": [],
          "items": {
            "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
            "type": "string"
          },
          "title": "Fact Ids",
          "type": "array"
        },
        "length_chars": {
          "maximum": 120,
          "minimum": 1,
          "title": "Length Chars",
          "type": "integer"
        },
        "line_kind": {
          "$ref": "#/$defs/YouTubeLineKind"
        },
        "pattern": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Pattern",
          "type": "string"
        },
        "promise": {
          "$ref": "#/$defs/YouTubePromise"
        },
        "score": {
          "maximum": 10,
          "minimum": 0,
          "title": "Score",
          "type": "integer"
        },
        "text": {
          "maxLength": 4096,
          "minLength": 1,
          "title": "Text",
          "type": "string"
        },
        "title_id": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Title Id",
          "type": "string"
        },
        "uppercase_anchor": {
          "maxLength": 4096,
          "minLength": 1,
          "title": "Uppercase Anchor",
          "type": "string"
        },
        "why": {
          "maxLength": 4096,
          "minLength": 1,
          "title": "Why",
          "type": "string"
        },
        "word_count": {
          "maximum": 20,
          "minimum": 1,
          "title": "Word Count",
          "type": "integer"
        }
      },
      "required": [
        "title_id",
        "text",
        "pattern",
        "uppercase_anchor",
        "length_chars",
        "word_count",
        "score",
        "why",
        "promise",
        "line_kind"
      ],
      "title": "YouTubeTitleCandidate",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "needs_review": {
      "default": true,
      "title": "Needs Review",
      "type": "boolean"
    },
    "primary_title_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Primary Title Id",
      "type": "string"
    },
    "project_id": {
      "pattern": "^ytp_[a-z0-9_]{2,120}$",
      "title": "Project Id",
      "type": "string"
    },
    "schema_name": {
      "const": "YouTubeTitlePackV1",
      "default": "YouTubeTitlePackV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "state": {
      "const": "draft",
      "default": "draft",
      "title": "State",
      "type": "string"
    },
    "title_pack_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Title Pack Id",
      "type": "string"
    },
    "titles": {
      "items": {
        "$ref": "#/$defs/YouTubeTitleCandidate"
      },
      "maxItems": 10,
      "minItems": 10,
      "title": "Titles",
      "type": "array"
    }
  },
  "required": [
    "title_pack_id",
    "project_id",
    "titles",
    "primary_title_id"
  ],
  "title": "YouTubeTitlePack",
  "type": "object"
}
