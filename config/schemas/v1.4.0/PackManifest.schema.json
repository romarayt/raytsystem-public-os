{
  "$defs": {
    "TrustClass": {
      "enum": [
        "primary",
        "official",
        "research",
        "user",
        "community",
        "generated",
        "untrusted"
      ],
      "title": "TrustClass",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "agent_ids": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Agent Ids",
      "type": "array"
    },
    "context_paths": {
      "default": [],
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "Context Paths",
      "type": "array"
    },
    "description": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Description",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "license_expression": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "License Expression",
      "type": "string"
    },
    "name": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Name",
      "type": "string"
    },
    "optional": {
      "default": true,
      "title": "Optional",
      "type": "boolean"
    },
    "pack_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Pack Id",
      "type": "string"
    },
    "schema_name": {
      "const": "PackManifestV1",
      "default": "PackManifestV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "skill_ids": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Skill Ids",
      "type": "array"
    },
    "trust_class": {
      "$ref": "#/$defs/TrustClass"
    },
    "version": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Version",
      "type": "string"
    }
  },
  "required": [
    "pack_id",
    "name",
    "version",
    "description",
    "license_expression",
    "trust_class"
  ],
  "title": "PackManifest",
  "type": "object"
}
