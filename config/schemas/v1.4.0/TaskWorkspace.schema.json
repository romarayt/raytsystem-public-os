{
  "$defs": {
    "WorkspaceMode": {
      "enum": [
        "workspace_root_readonly",
        "task_worktree",
        "approved_external_root"
      ],
      "title": "WorkspaceMode",
      "type": "string"
    },
    "WorkspaceStatus": {
      "enum": [
        "preparing",
        "ready",
        "active",
        "stale",
        "blocked"
      ],
      "title": "WorkspaceStatus",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "artifacts_path": {
      "minLength": 1,
      "title": "Artifacts Path",
      "type": "string"
    },
    "context_path": {
      "minLength": 1,
      "title": "Context Path",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "git_commit": {
      "pattern": "^[0-9a-f]{40,64}$",
      "title": "Git Commit",
      "type": "string"
    },
    "graph_fingerprint": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Graph Fingerprint",
      "type": "string"
    },
    "graph_snapshot_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Graph Snapshot Id",
      "type": "string"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "logs_path": {
      "minLength": 1,
      "title": "Logs Path",
      "type": "string"
    },
    "manifest_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Manifest Sha256",
      "type": "string"
    },
    "mode": {
      "$ref": "#/$defs/WorkspaceMode"
    },
    "relative_root": {
      "minLength": 1,
      "title": "Relative Root",
      "type": "string"
    },
    "repo_path": {
      "minLength": 1,
      "title": "Repo Path",
      "type": "string"
    },
    "schema_name": {
      "const": "TaskWorkspaceV1",
      "default": "TaskWorkspaceV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/WorkspaceStatus",
      "default": "ready"
    },
    "task_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Task Id",
      "type": "string"
    },
    "updated_at": {
      "format": "date-time",
      "title": "Updated At",
      "type": "string"
    },
    "workspace_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Workspace Id",
      "type": "string"
    }
  },
  "required": [
    "workspace_id",
    "task_id",
    "mode",
    "relative_root",
    "repo_path",
    "context_path",
    "artifacts_path",
    "logs_path",
    "git_commit",
    "graph_snapshot_id",
    "graph_fingerprint",
    "manifest_sha256",
    "created_at",
    "updated_at"
  ],
  "title": "TaskWorkspace",
  "type": "object"
}
