{
  "$defs": {
    "WorkflowNodeType": {
      "enum": [
        "task",
        "agent",
        "deterministic_command",
        "review",
        "approval",
        "condition",
        "wait",
        "artifact",
        "notification",
        "subworkflow"
      ],
      "title": "WorkflowNodeType",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "agent_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Agent Id"
    },
    "approval_gate_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Approval Gate Id"
    },
    "condition_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Condition Id"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "idempotency_scope": {
      "default": "workflow_run",
      "enum": [
        "workflow_run",
        "task",
        "global"
      ],
      "title": "Idempotency Scope",
      "type": "string"
    },
    "input_schema_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Input Schema Sha256",
      "type": "string"
    },
    "name": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Name",
      "type": "string"
    },
    "node_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Node Id",
      "type": "string"
    },
    "node_type": {
      "$ref": "#/$defs/WorkflowNodeType"
    },
    "operation_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Operation Id"
    },
    "output_schema_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Output Schema Sha256",
      "type": "string"
    },
    "retry_policy_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Retry Policy Id"
    },
    "schema_name": {
      "const": "WorkflowNodeV1",
      "default": "WorkflowNodeV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "subworkflow_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Subworkflow Id"
    },
    "timeout_seconds": {
      "default": 300,
      "maximum": 86400,
      "minimum": 1,
      "title": "Timeout Seconds",
      "type": "integer"
    }
  },
  "required": [
    "node_id",
    "node_type",
    "name",
    "input_schema_sha256",
    "output_schema_sha256"
  ],
  "title": "WorkflowNode",
  "type": "object"
}
