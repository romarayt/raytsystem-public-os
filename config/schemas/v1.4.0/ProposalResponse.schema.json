{
  "$defs": {
    "ComponentRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Artifact Sha256"
        },
        "config_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Config Sha256",
          "type": "string"
        },
        "name": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Name",
          "type": "string"
        },
        "version": {
          "maxLength": 4096,
          "minLength": 1,
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "name",
        "version",
        "config_sha256"
      ],
      "title": "ComponentRef",
      "type": "object"
    },
    "ProducerKind": {
      "enum": [
        "kernel",
        "human",
        "model",
        "skill",
        "adapter"
      ],
      "title": "ProducerKind",
      "type": "string"
    },
    "ProducerRef": {
      "additionalProperties": false,
      "properties": {
        "component": {
          "$ref": "#/$defs/ComponentRef"
        },
        "destination": {
          "anyOf": [
            {
              "maxLength": 4096,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Destination"
        },
        "kind": {
          "$ref": "#/$defs/ProducerKind"
        }
      },
      "required": [
        "kind",
        "component"
      ],
      "title": "ProducerRef",
      "type": "object"
    },
    "ProposalItem": {
      "additionalProperties": false,
      "properties": {
        "evidence_ids": {
          "items": {
            "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
            "type": "string"
          },
          "title": "Evidence Ids",
          "type": "array"
        },
        "extensions": {
          "additionalProperties": true,
          "title": "Extensions",
          "type": "object"
        },
        "id_scheme_version": {
          "default": "1",
          "title": "Id Scheme Version",
          "type": "string"
        },
        "kind": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Kind",
          "type": "string"
        },
        "payload": {
          "additionalProperties": true,
          "title": "Payload",
          "type": "object"
        },
        "proposal_item_id": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Proposal Item Id",
          "type": "string"
        },
        "schema_name": {
          "const": "ProposalItemV1",
          "default": "ProposalItemV1",
          "title": "Schema Name",
          "type": "string"
        },
        "schema_version": {
          "default": "1.4.0",
          "title": "Schema Version",
          "type": "string"
        }
      },
      "required": [
        "proposal_item_id",
        "kind",
        "payload",
        "evidence_ids"
      ],
      "title": "ProposalItem",
      "type": "object"
    },
    "RecordRef": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Kind",
          "type": "string"
        },
        "object_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Object Sha256",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "id",
        "object_sha256"
      ],
      "title": "RecordRef",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "allowed_evidence_ids": {
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Allowed Evidence Ids",
      "type": "array"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "producer": {
      "$ref": "#/$defs/ProducerRef"
    },
    "proposal_response_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Proposal Response Id",
      "type": "string"
    },
    "proposed_items": {
      "items": {
        "$ref": "#/$defs/ProposalItem"
      },
      "title": "Proposed Items",
      "type": "array"
    },
    "raw_response_sha256": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Raw Response Sha256"
    },
    "request_ref": {
      "$ref": "#/$defs/RecordRef"
    },
    "schema_name": {
      "const": "ProposalResponseV1",
      "default": "ProposalResponseV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "proposal_response_id",
    "request_ref",
    "producer",
    "allowed_evidence_ids",
    "proposed_items",
    "created_at"
  ],
  "title": "ProposalResponse",
  "type": "object"
}
