{
  "additionalProperties": false,
  "properties": {
    "condition_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Condition Id",
      "type": "string"
    },
    "expected": {
      "default": null,
      "title": "Expected"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "input_name": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Input Name",
      "type": "string"
    },
    "operation": {
      "enum": [
        "equals",
        "not_equals",
        "contains",
        "exists",
        "all_passed",
        "any_failed"
      ],
      "title": "Operation",
      "type": "string"
    },
    "schema_name": {
      "const": "WorkflowConditionV1",
      "default": "WorkflowConditionV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "condition_id",
    "operation",
    "input_name"
  ],
  "title": "WorkflowCondition",
  "type": "object"
}
