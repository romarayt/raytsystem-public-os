{
  "additionalProperties": false,
  "properties": {
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "invocation_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Invocation Sha256",
      "type": "string"
    },
    "original_run_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Original Run Id",
      "type": "string"
    },
    "recorded_at": {
      "format": "date-time",
      "title": "Recorded At",
      "type": "string"
    },
    "recorded_result_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Recorded Result Id",
      "type": "string"
    },
    "result_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Result Sha256",
      "type": "string"
    },
    "schema_name": {
      "const": "RecordedSideEffectResultV1",
      "default": "RecordedSideEffectResultV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "side_effect_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Side Effect Id",
      "type": "string"
    }
  },
  "required": [
    "recorded_result_id",
    "original_run_id",
    "side_effect_id",
    "invocation_sha256",
    "result_sha256",
    "recorded_at"
  ],
  "title": "RecordedSideEffectResult",
  "type": "object"
}
