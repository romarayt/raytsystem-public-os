{
  "$defs": {
    "RedactionStatus": {
      "enum": [
        "not_required",
        "redacted",
        "rejected"
      ],
      "title": "RedactionStatus",
      "type": "string"
    },
    "SpanKind": {
      "enum": [
        "task",
        "run",
        "model",
        "graph_query",
        "retrieval",
        "tool",
        "filesystem",
        "approval",
        "test",
        "artifact"
      ],
      "title": "SpanKind",
      "type": "string"
    },
    "SpanStatus": {
      "enum": [
        "unset",
        "ok",
        "error",
        "cancelled",
        "blocked"
      ],
      "title": "SpanStatus",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "actual_cost": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Actual Cost"
    },
    "agent_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Agent Id"
    },
    "approval_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Approval Id"
    },
    "attributes": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Attributes",
      "type": "object"
    },
    "cached_tokens": {
      "default": 0,
      "minimum": 0,
      "title": "Cached Tokens",
      "type": "integer"
    },
    "duration_ms": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Duration Ms"
    },
    "employee_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Employee Id"
    },
    "ended_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Ended At"
    },
    "error_code": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Error Code"
    },
    "estimated_cost": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "default": "0",
      "title": "Estimated Cost"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "graph_snapshot_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Graph Snapshot Id"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "input_tokens": {
      "default": 0,
      "minimum": 0,
      "title": "Input Tokens",
      "type": "integer"
    },
    "knowledge_generation_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Knowledge Generation Id"
    },
    "model": {
      "anyOf": [
        {
          "maxLength": 4096,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Model"
    },
    "operation_name": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Operation Name",
      "type": "string"
    },
    "output_tokens": {
      "default": 0,
      "minimum": 0,
      "title": "Output Tokens",
      "type": "integer"
    },
    "parent_span_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Parent Span Id"
    },
    "policy_decision_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Policy Decision Id"
    },
    "provider": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Provider"
    },
    "redaction_status": {
      "$ref": "#/$defs/RedactionStatus",
      "default": "not_required"
    },
    "retry_count": {
      "default": 0,
      "maximum": 1000,
      "minimum": 0,
      "title": "Retry Count",
      "type": "integer"
    },
    "run_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Run Id",
      "type": "string"
    },
    "schema_name": {
      "const": "TraceSpanV1",
      "default": "TraceSpanV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "session_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Session Id"
    },
    "span_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Span Id",
      "type": "string"
    },
    "span_kind": {
      "$ref": "#/$defs/SpanKind"
    },
    "started_at": {
      "format": "date-time",
      "title": "Started At",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/SpanStatus",
      "default": "unset"
    },
    "task_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Task Id"
    },
    "tool_name": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Tool Name"
    },
    "trace_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Trace Id",
      "type": "string"
    },
    "workspace_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Workspace Id",
      "type": "string"
    }
  },
  "required": [
    "trace_id",
    "span_id",
    "span_kind",
    "run_id",
    "workspace_id",
    "operation_name",
    "started_at"
  ],
  "title": "TraceSpan",
  "type": "object"
}
