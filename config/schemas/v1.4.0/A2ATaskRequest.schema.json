{
  "additionalProperties": false,
  "properties": {
    "agent_card_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Agent Card Id",
      "type": "string"
    },
    "artifact_hashes": {
      "patternProperties": {
        "^[a-z][a-z0-9_:.@/-]{1,255}$": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        }
      },
      "title": "Artifact Hashes",
      "type": "object"
    },
    "authentication_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Authentication Sha256",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "extension_ids": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Extension Ids",
      "type": "array"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "local_proposal_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Local Proposal Id"
    },
    "protocol_version": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Protocol Version",
      "type": "string"
    },
    "quarantined": {
      "default": true,
      "title": "Quarantined",
      "type": "boolean"
    },
    "remote_identity": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Remote Identity",
      "type": "string"
    },
    "request_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Request Id",
      "type": "string"
    },
    "schema_name": {
      "const": "A2ATaskRequestV1",
      "default": "A2ATaskRequestV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "task_payload_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Task Payload Sha256",
      "type": "string"
    },
    "trusted": {
      "const": false,
      "default": false,
      "title": "Trusted",
      "type": "boolean"
    }
  },
  "required": [
    "request_id",
    "remote_identity",
    "authentication_sha256",
    "agent_card_id",
    "protocol_version",
    "task_payload_sha256",
    "created_at"
  ],
  "title": "A2ATaskRequest",
  "type": "object"
}
