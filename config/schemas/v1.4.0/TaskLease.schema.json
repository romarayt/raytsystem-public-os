{
  "$defs": {
    "TaskLeaseStatus": {
      "enum": [
        "active",
        "frozen",
        "released",
        "expired",
        "revoked"
      ],
      "title": "TaskLeaseStatus",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "acquired_at": {
      "format": "date-time",
      "title": "Acquired At",
      "type": "string"
    },
    "control_epoch": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Control Epoch",
      "type": "string"
    },
    "employee_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Employee Id",
      "type": "string"
    },
    "expires_at": {
      "format": "date-time",
      "title": "Expires At",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "fencing_token": {
      "exclusiveMinimum": 0,
      "title": "Fencing Token",
      "type": "integer"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "lease_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Lease Id",
      "type": "string"
    },
    "run_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Run Id",
      "type": "string"
    },
    "schema_name": {
      "const": "TaskLeaseV1",
      "default": "TaskLeaseV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/TaskLeaseStatus",
      "default": "active"
    },
    "task_generation_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Task Generation Id",
      "type": "string"
    },
    "task_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Task Id",
      "type": "string"
    },
    "task_revision": {
      "minimum": 1,
      "title": "Task Revision",
      "type": "integer"
    }
  },
  "required": [
    "lease_id",
    "task_id",
    "employee_id",
    "run_id",
    "task_generation_id",
    "task_revision",
    "control_epoch",
    "fencing_token",
    "acquired_at",
    "expires_at"
  ],
  "title": "TaskLease",
  "type": "object"
}
