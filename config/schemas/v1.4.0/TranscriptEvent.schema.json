{
  "additionalProperties": false,
  "properties": {
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "event_type": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Event Type",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "redacted": {
      "default": false,
      "title": "Redacted",
      "type": "boolean"
    },
    "run_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Run Id",
      "type": "string"
    },
    "schema_name": {
      "const": "TranscriptEventV1",
      "default": "TranscriptEventV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "sequence": {
      "maximum": 10000000,
      "minimum": 0,
      "title": "Sequence",
      "type": "integer"
    },
    "stream": {
      "enum": [
        "system",
        "stdout",
        "stderr",
        "tool",
        "result"
      ],
      "title": "Stream",
      "type": "string"
    },
    "text": {
      "default": "",
      "maxLength": 32768,
      "title": "Text",
      "type": "string"
    },
    "transcript_event_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Transcript Event Id",
      "type": "string"
    }
  },
  "required": [
    "transcript_event_id",
    "run_id",
    "sequence",
    "stream",
    "event_type",
    "created_at"
  ],
  "title": "TranscriptEvent",
  "type": "object"
}
