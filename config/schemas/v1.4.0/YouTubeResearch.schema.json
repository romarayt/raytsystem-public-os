{
  "$defs": {
    "YouTubeEvidenceSpan": {
      "additionalProperties": false,
      "properties": {
        "end_byte": {
          "exclusiveMinimum": 0,
          "title": "End Byte",
          "type": "integer"
        },
        "quote_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Quote Sha256",
          "type": "string"
        },
        "source_path": {
          "minLength": 1,
          "title": "Source Path",
          "type": "string"
        },
        "source_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Source Sha256",
          "type": "string"
        },
        "start_byte": {
          "minimum": 0,
          "title": "Start Byte",
          "type": "integer"
        }
      },
      "required": [
        "source_path",
        "source_sha256",
        "start_byte",
        "end_byte",
        "quote_sha256"
      ],
      "title": "YouTubeEvidenceSpan",
      "type": "object"
    },
    "YouTubeFact": {
      "additionalProperties": false,
      "properties": {
        "checked_at": {
          "format": "date-time",
          "title": "Checked At",
          "type": "string"
        },
        "claim": {
          "maxLength": 4096,
          "minLength": 1,
          "title": "Claim",
          "type": "string"
        },
        "contradicts": {
          "default": [],
          "items": {
            "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
            "type": "string"
          },
          "title": "Contradicts",
          "type": "array"
        },
        "display_value": {
          "anyOf": [
            {
              "maxLength": 4096,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Display Value"
        },
        "evidence": {
          "$ref": "#/$defs/YouTubeEvidenceSpan"
        },
        "fact_id": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Fact Id",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/YouTubeFactStatus"
        },
        "supersedes": {
          "default": [],
          "items": {
            "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
            "type": "string"
          },
          "title": "Supersedes",
          "type": "array"
        },
        "synthetic_only": {
          "const": true,
          "default": true,
          "title": "Synthetic Only",
          "type": "boolean"
        }
      },
      "required": [
        "fact_id",
        "claim",
        "status",
        "evidence",
        "checked_at"
      ],
      "title": "YouTubeFact",
      "type": "object"
    },
    "YouTubeFactStatus": {
      "enum": [
        "supported",
        "disputed",
        "unsupported"
      ],
      "title": "YouTubeFactStatus",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "facts": {
      "items": {
        "$ref": "#/$defs/YouTubeFact"
      },
      "minItems": 1,
      "title": "Facts",
      "type": "array"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "needs_review": {
      "default": true,
      "title": "Needs Review",
      "type": "boolean"
    },
    "project_id": {
      "pattern": "^ytp_[a-z0-9_]{2,120}$",
      "title": "Project Id",
      "type": "string"
    },
    "research_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Research Id",
      "type": "string"
    },
    "schema_name": {
      "const": "YouTubeResearchV1",
      "default": "YouTubeResearchV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "state": {
      "const": "draft",
      "default": "draft",
      "title": "State",
      "type": "string"
    }
  },
  "required": [
    "research_id",
    "project_id",
    "facts"
  ],
  "title": "YouTubeResearch",
  "type": "object"
}
