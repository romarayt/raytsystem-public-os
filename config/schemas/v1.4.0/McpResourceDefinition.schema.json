{
  "$defs": {
    "Sensitivity": {
      "enum": [
        "public",
        "internal",
        "confidential",
        "restricted",
        "secret"
      ],
      "title": "Sensitivity",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "catalog_only": {
      "default": true,
      "title": "Catalog Only",
      "type": "boolean"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "resource_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Resource Id",
      "type": "string"
    },
    "schema_name": {
      "const": "McpResourceDefinitionV1",
      "default": "McpResourceDefinitionV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "sensitivity": {
      "$ref": "#/$defs/Sensitivity",
      "default": "internal"
    },
    "server_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Server Id",
      "type": "string"
    },
    "uri_template": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Uri Template",
      "type": "string"
    }
  },
  "required": [
    "resource_id",
    "server_id",
    "uri_template"
  ],
  "title": "McpResourceDefinition",
  "type": "object"
}
