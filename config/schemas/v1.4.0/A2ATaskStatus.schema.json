{
  "additionalProperties": false,
  "properties": {
    "artifact_ids": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Artifact Ids",
      "type": "array"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "local_task_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Local Task Id"
    },
    "policy_decision_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Policy Decision Id",
      "type": "string"
    },
    "request_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Request Id",
      "type": "string"
    },
    "schema_name": {
      "const": "A2ATaskStatusV1",
      "default": "A2ATaskStatusV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "state": {
      "enum": [
        "received",
        "quarantined",
        "proposed",
        "accepted",
        "running",
        "done",
        "cancelled",
        "rejected"
      ],
      "title": "State",
      "type": "string"
    },
    "status_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Status Id",
      "type": "string"
    },
    "updated_at": {
      "format": "date-time",
      "title": "Updated At",
      "type": "string"
    }
  },
  "required": [
    "status_id",
    "request_id",
    "state",
    "policy_decision_id",
    "updated_at"
  ],
  "title": "A2ATaskStatus",
  "type": "object"
}
