{
  "$defs": {
    "TaskEventKind": {
      "enum": [
        "created",
        "transitioned",
        "cancelled"
      ],
      "title": "TaskEventKind",
      "type": "string"
    },
    "TaskStatus": {
      "enum": [
        "inbox",
        "planned",
        "ready",
        "running",
        "review",
        "blocked",
        "done",
        "cancelled"
      ],
      "title": "TaskStatus",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "actor": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Actor",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "event_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Event Id",
      "type": "string"
    },
    "event_kind": {
      "$ref": "#/$defs/TaskEventKind"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "from_status": {
      "anyOf": [
        {
          "$ref": "#/$defs/TaskStatus"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "idempotency_key": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Idempotency Key",
      "type": "string"
    },
    "operation_key": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Operation Key",
      "type": "string"
    },
    "previous_event_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Previous Event Id"
    },
    "previous_task_sha256": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Previous Task Sha256"
    },
    "schema_name": {
      "const": "TaskEventV1",
      "default": "TaskEventV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "task_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Task Id",
      "type": "string"
    },
    "task_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Task Sha256",
      "type": "string"
    },
    "to_status": {
      "$ref": "#/$defs/TaskStatus"
    }
  },
  "required": [
    "event_id",
    "event_kind",
    "task_id",
    "operation_key",
    "idempotency_key",
    "task_sha256",
    "to_status",
    "actor",
    "created_at"
  ],
  "title": "TaskEvent",
  "type": "object"
}
