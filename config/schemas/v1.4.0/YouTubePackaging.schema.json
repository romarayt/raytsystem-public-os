{
  "$defs": {
    "YouTubeAlignment": {
      "enum": [
        "exact",
        "compatible",
        "mismatch",
        "contradict"
      ],
      "title": "YouTubeAlignment",
      "type": "string"
    },
    "YouTubePackagePair": {
      "additionalProperties": false,
      "properties": {
        "alignment": {
          "$ref": "#/$defs/YouTubeAlignment"
        },
        "concept_id": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Concept Id",
          "type": "string"
        },
        "first_seven_seconds": {
          "maxLength": 4096,
          "minLength": 1,
          "title": "First Seven Seconds",
          "type": "string"
        },
        "pair_id": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Pair Id",
          "type": "string"
        },
        "score": {
          "$ref": "#/$defs/YouTubePairScore"
        },
        "title_id": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Title Id",
          "type": "string"
        },
        "total": {
          "maximum": 30,
          "minimum": 0,
          "title": "Total",
          "type": "integer"
        }
      },
      "required": [
        "pair_id",
        "title_id",
        "concept_id",
        "alignment",
        "score",
        "total",
        "first_seven_seconds"
      ],
      "title": "YouTubePackagePair",
      "type": "object"
    },
    "YouTubePairScore": {
      "additionalProperties": false,
      "properties": {
        "clarity": {
          "maximum": 5,
          "minimum": 0,
          "title": "Clarity",
          "type": "integer"
        },
        "curiosity": {
          "maximum": 5,
          "minimum": 0,
          "title": "Curiosity",
          "type": "integer"
        },
        "expectation_match": {
          "maximum": 5,
          "minimum": 0,
          "title": "Expectation Match",
          "type": "integer"
        },
        "mobile": {
          "maximum": 5,
          "minimum": 0,
          "title": "Mobile",
          "type": "integer"
        },
        "next_step": {
          "maximum": 5,
          "minimum": 0,
          "title": "Next Step",
          "type": "integer"
        },
        "roma_fit": {
          "maximum": 5,
          "minimum": 0,
          "title": "Roma Fit",
          "type": "integer"
        }
      },
      "required": [
        "clarity",
        "curiosity",
        "expectation_match",
        "mobile",
        "roma_fit",
        "next_step"
      ],
      "title": "YouTubePairScore",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "needs_review": {
      "default": true,
      "title": "Needs Review",
      "type": "boolean"
    },
    "packaging_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Packaging Id",
      "type": "string"
    },
    "pairs": {
      "items": {
        "$ref": "#/$defs/YouTubePackagePair"
      },
      "maxItems": 3,
      "minItems": 3,
      "title": "Pairs",
      "type": "array"
    },
    "project_id": {
      "pattern": "^ytp_[a-z0-9_]{2,120}$",
      "title": "Project Id",
      "type": "string"
    },
    "recommended_pair_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Recommended Pair Id",
      "type": "string"
    },
    "schema_name": {
      "const": "YouTubePackagingV1",
      "default": "YouTubePackagingV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "state": {
      "const": "draft",
      "default": "draft",
      "title": "State",
      "type": "string"
    }
  },
  "required": [
    "packaging_id",
    "project_id",
    "pairs",
    "recommended_pair_id"
  ],
  "title": "YouTubePackaging",
  "type": "object"
}
