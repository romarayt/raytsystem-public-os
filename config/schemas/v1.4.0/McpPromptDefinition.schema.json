{
  "$defs": {
    "Sensitivity": {
      "enum": [
        "public",
        "internal",
        "confidential",
        "restricted",
        "secret"
      ],
      "title": "Sensitivity",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "catalog_only": {
      "default": true,
      "title": "Catalog Only",
      "type": "boolean"
    },
    "content_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Content Sha256",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "name": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Name",
      "type": "string"
    },
    "prompt_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Prompt Id",
      "type": "string"
    },
    "schema_name": {
      "const": "McpPromptDefinitionV1",
      "default": "McpPromptDefinitionV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "sensitivity": {
      "$ref": "#/$defs/Sensitivity",
      "default": "internal"
    },
    "server_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Server Id",
      "type": "string"
    }
  },
  "required": [
    "prompt_id",
    "server_id",
    "name",
    "content_sha256"
  ],
  "title": "McpPromptDefinition",
  "type": "object"
}
