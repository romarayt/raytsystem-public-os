{
  "$defs": {
    "SpanStatus": {
      "enum": [
        "unset",
        "ok",
        "error",
        "cancelled",
        "blocked"
      ],
      "title": "SpanStatus",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "actual_cost": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Actual Cost"
    },
    "cached_tokens": {
      "default": 0,
      "minimum": 0,
      "title": "Cached Tokens",
      "type": "integer"
    },
    "completed_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Completed At"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "estimated_cost": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "default": "0",
      "title": "Estimated Cost"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "input_tokens": {
      "default": 0,
      "minimum": 0,
      "title": "Input Tokens",
      "type": "integer"
    },
    "output_tokens": {
      "default": 0,
      "minimum": 0,
      "title": "Output Tokens",
      "type": "integer"
    },
    "root_run_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Root Run Id",
      "type": "string"
    },
    "root_span_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Root Span Id",
      "type": "string"
    },
    "schema_name": {
      "const": "TraceRecordV1",
      "default": "TraceRecordV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "span_count": {
      "default": 0,
      "minimum": 0,
      "title": "Span Count",
      "type": "integer"
    },
    "status": {
      "$ref": "#/$defs/SpanStatus",
      "default": "unset"
    },
    "task_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Task Id"
    },
    "trace_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Trace Id",
      "type": "string"
    }
  },
  "required": [
    "trace_id",
    "root_run_id",
    "root_span_id",
    "created_at"
  ],
  "title": "TraceRecord",
  "type": "object"
}
