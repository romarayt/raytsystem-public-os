{
  "additionalProperties": false,
  "properties": {
    "accepted_by": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Accepted By",
      "type": "string"
    },
    "aggregate_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Aggregate Sha256",
      "type": "string"
    },
    "approval_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Approval Id",
      "type": "string"
    },
    "baseline_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Baseline Id",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "eval_run_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Eval Run Id",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "result_hashes": {
      "patternProperties": {
        "^[a-z][a-z0-9_:.@/-]{1,255}$": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        }
      },
      "title": "Result Hashes",
      "type": "object"
    },
    "schema_name": {
      "const": "EvalBaselineV1",
      "default": "EvalBaselineV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "suite_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Suite Id",
      "type": "string"
    },
    "suite_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Suite Sha256",
      "type": "string"
    }
  },
  "required": [
    "baseline_id",
    "suite_id",
    "suite_sha256",
    "eval_run_id",
    "result_hashes",
    "aggregate_sha256",
    "accepted_by",
    "approval_id",
    "created_at"
  ],
  "title": "EvalBaseline",
  "type": "object"
}
