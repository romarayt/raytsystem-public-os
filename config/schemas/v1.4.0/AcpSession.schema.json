{
  "additionalProperties": false,
  "properties": {
    "acp_session_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Acp Session Id",
      "type": "string"
    },
    "adapter_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Adapter Id",
      "type": "string"
    },
    "capability_set_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Capability Set Id",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "resume_token_sha256": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Resume Token Sha256"
    },
    "runtime_session_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Runtime Session Id",
      "type": "string"
    },
    "schema_name": {
      "const": "AcpSessionV1",
      "default": "AcpSessionV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "state": {
      "enum": [
        "initializing",
        "ready",
        "streaming",
        "cancelled",
        "closed",
        "failed"
      ],
      "title": "State",
      "type": "string"
    },
    "updated_at": {
      "format": "date-time",
      "title": "Updated At",
      "type": "string"
    },
    "workspace_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Workspace Id",
      "type": "string"
    }
  },
  "required": [
    "acp_session_id",
    "runtime_session_id",
    "adapter_id",
    "capability_set_id",
    "workspace_id",
    "state",
    "created_at",
    "updated_at"
  ],
  "title": "AcpSession",
  "type": "object"
}
