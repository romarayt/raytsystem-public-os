{
  "$defs": {
    "CodeGraphQueryEdge": {
      "additionalProperties": false,
      "description": "Compact context slice of one CodeEdge.\n\nSource file, location and extractor provenance stay on the snapshot edge and\nremain addressable through the stable ``edge_id``.",
      "properties": {
        "confidence": {
          "$ref": "#/$defs/EdgeConfidence"
        },
        "edge_id": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Edge Id",
          "type": "string"
        },
        "extensions": {
          "additionalProperties": true,
          "title": "Extensions",
          "type": "object"
        },
        "id_scheme_version": {
          "default": "1",
          "title": "Id Scheme Version",
          "type": "string"
        },
        "relation": {
          "$ref": "#/$defs/CodeRelation"
        },
        "schema_name": {
          "const": "GraphQueryEdgeV1",
          "default": "GraphQueryEdgeV1",
          "title": "Schema Name",
          "type": "string"
        },
        "schema_version": {
          "default": "1.4.0",
          "title": "Schema Version",
          "type": "string"
        },
        "source": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Source",
          "type": "string"
        },
        "target": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Target",
          "type": "string"
        }
      },
      "required": [
        "edge_id",
        "source",
        "target",
        "relation",
        "confidence"
      ],
      "title": "CodeGraphQueryEdge",
      "type": "object"
    },
    "CodeGraphQueryNode": {
      "additionalProperties": false,
      "description": "Compact context slice of one CodeNode; full provenance stays in the snapshot.",
      "properties": {
        "community_id": {
          "anyOf": [
            {
              "maximum": 1000000,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Community Id"
        },
        "depth": {
          "default": 0,
          "maximum": 16,
          "minimum": 0,
          "title": "Depth",
          "type": "integer"
        },
        "extensions": {
          "additionalProperties": true,
          "title": "Extensions",
          "type": "object"
        },
        "id_scheme_version": {
          "default": "1",
          "title": "Id Scheme Version",
          "type": "string"
        },
        "is_bridge": {
          "default": false,
          "title": "Is Bridge",
          "type": "boolean"
        },
        "is_god": {
          "default": false,
          "title": "Is God",
          "type": "boolean"
        },
        "kind": {
          "$ref": "#/$defs/CodeNodeKind"
        },
        "label": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Label",
          "type": "string"
        },
        "location": {
          "anyOf": [
            {
              "$ref": "#/$defs/CodeSourceLocation"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "node_id": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Node Id",
          "type": "string"
        },
        "path": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Path"
        },
        "qualified_name": {
          "default": "",
          "maxLength": 1024,
          "title": "Qualified Name",
          "type": "string"
        },
        "schema_name": {
          "const": "GraphQueryNodeV1",
          "default": "GraphQueryNodeV1",
          "title": "Schema Name",
          "type": "string"
        },
        "schema_version": {
          "default": "1.4.0",
          "title": "Schema Version",
          "type": "string"
        }
      },
      "required": [
        "node_id",
        "kind",
        "label"
      ],
      "title": "CodeGraphQueryNode",
      "type": "object"
    },
    "CodeNodeKind": {
      "enum": [
        "repository",
        "directory",
        "file",
        "module",
        "package",
        "class",
        "function",
        "method",
        "api_endpoint",
        "database_table",
        "database_schema",
        "configuration",
        "test",
        "adr",
        "rationale",
        "dependency"
      ],
      "title": "CodeNodeKind",
      "type": "string"
    },
    "CodeRelation": {
      "enum": [
        "contains",
        "defines",
        "imports",
        "calls",
        "inherits",
        "implements",
        "references",
        "depends_on",
        "configured_by",
        "tests",
        "explained_by",
        "implemented_by",
        "explains",
        "verifies",
        "changed",
        "touches",
        "operates_on"
      ],
      "title": "CodeRelation",
      "type": "string"
    },
    "CodeSourceLocation": {
      "additionalProperties": false,
      "properties": {
        "end_column": {
          "default": 0,
          "maximum": 10000000,
          "minimum": 0,
          "title": "End Column",
          "type": "integer"
        },
        "end_line": {
          "maximum": 10000000,
          "minimum": 1,
          "title": "End Line",
          "type": "integer"
        },
        "extensions": {
          "additionalProperties": true,
          "title": "Extensions",
          "type": "object"
        },
        "id_scheme_version": {
          "default": "1",
          "title": "Id Scheme Version",
          "type": "string"
        },
        "schema_name": {
          "const": "CodeSourceLocationV1",
          "default": "CodeSourceLocationV1",
          "title": "Schema Name",
          "type": "string"
        },
        "schema_version": {
          "default": "1.4.0",
          "title": "Schema Version",
          "type": "string"
        },
        "start_column": {
          "default": 0,
          "maximum": 10000000,
          "minimum": 0,
          "title": "Start Column",
          "type": "integer"
        },
        "start_line": {
          "maximum": 10000000,
          "minimum": 1,
          "title": "Start Line",
          "type": "integer"
        }
      },
      "required": [
        "start_line",
        "end_line"
      ],
      "title": "CodeSourceLocation",
      "type": "object"
    },
    "EdgeConfidence": {
      "enum": [
        "EXTRACTED",
        "INFERRED",
        "AMBIGUOUS"
      ],
      "title": "EdgeConfidence",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "edges": {
      "items": {
        "$ref": "#/$defs/CodeGraphQueryEdge"
      },
      "title": "Edges",
      "type": "array"
    },
    "estimated_context_bytes": {
      "default": 0,
      "minimum": 0,
      "title": "Estimated Context Bytes",
      "type": "integer"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "fallback_reason": {
      "anyOf": [
        {
          "maxLength": 512,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Fallback Reason"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "nodes": {
      "items": {
        "$ref": "#/$defs/CodeGraphQueryNode"
      },
      "title": "Nodes",
      "type": "array"
    },
    "operation": {
      "enum": [
        "query",
        "explain",
        "neighbors",
        "path",
        "impact"
      ],
      "title": "Operation",
      "type": "string"
    },
    "ordered_node_ids": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Ordered Node Ids",
      "type": "array"
    },
    "query_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Query Sha256",
      "type": "string"
    },
    "schema_name": {
      "const": "GraphQueryResultV1",
      "default": "GraphQueryResultV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "seed_node_ids": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Seed Node Ids",
      "type": "array"
    },
    "snapshot_fingerprint": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Snapshot Fingerprint",
      "type": "string"
    },
    "snapshot_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Snapshot Id",
      "type": "string"
    },
    "truncated": {
      "default": false,
      "title": "Truncated",
      "type": "boolean"
    }
  },
  "required": [
    "operation",
    "snapshot_id",
    "snapshot_fingerprint",
    "query_sha256",
    "nodes",
    "edges"
  ],
  "title": "CodeGraphQueryResult",
  "type": "object"
}
