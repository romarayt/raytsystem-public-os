{
  "$defs": {
    "EvalScore": {
      "additionalProperties": false,
      "properties": {
        "deterministic": {
          "title": "Deterministic",
          "type": "boolean"
        },
        "extensions": {
          "additionalProperties": true,
          "title": "Extensions",
          "type": "object"
        },
        "id_scheme_version": {
          "default": "1",
          "title": "Id Scheme Version",
          "type": "string"
        },
        "maximum": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Maximum"
        },
        "name": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Name",
          "type": "string"
        },
        "schema_name": {
          "const": "EvalScoreV1",
          "default": "EvalScoreV1",
          "title": "Schema Name",
          "type": "string"
        },
        "schema_version": {
          "default": "1.4.0",
          "title": "Schema Version",
          "type": "string"
        },
        "score_id": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Score Id",
          "type": "string"
        },
        "unit": {
          "default": "ratio",
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Unit",
          "type": "string"
        },
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ],
          "title": "Value"
        }
      },
      "required": [
        "score_id",
        "name",
        "value",
        "maximum",
        "deterministic"
      ],
      "title": "EvalScore",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "artifact_hashes": {
      "patternProperties": {
        "^[a-z][a-z0-9_:.@/-]{1,255}$": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        }
      },
      "title": "Artifact Hashes",
      "type": "object"
    },
    "assertion_results": {
      "patternProperties": {
        "^[a-z][a-z0-9_:.@/-]{1,255}$": {
          "type": "boolean"
        }
      },
      "title": "Assertion Results",
      "type": "object"
    },
    "case_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Case Id",
      "type": "string"
    },
    "cost": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        }
      ],
      "default": "0",
      "title": "Cost"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "duration_ms": {
      "minimum": 0,
      "title": "Duration Ms",
      "type": "integer"
    },
    "eval_run_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Eval Run Id",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "failed_assertion_ids": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Failed Assertion Ids",
      "type": "array"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "judge_score_ids": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Judge Score Ids",
      "type": "array"
    },
    "passed": {
      "title": "Passed",
      "type": "boolean"
    },
    "result_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Result Id",
      "type": "string"
    },
    "schema_name": {
      "const": "EvalResultV1",
      "default": "EvalResultV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "scores": {
      "items": {
        "$ref": "#/$defs/EvalScore"
      },
      "title": "Scores",
      "type": "array"
    }
  },
  "required": [
    "result_id",
    "eval_run_id",
    "case_id",
    "passed",
    "assertion_results",
    "scores",
    "duration_ms",
    "created_at"
  ],
  "title": "EvalResult",
  "type": "object"
}
