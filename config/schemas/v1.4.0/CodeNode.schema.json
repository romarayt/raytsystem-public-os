{
  "$defs": {
    "CodeNodeKind": {
      "enum": [
        "repository",
        "directory",
        "file",
        "module",
        "package",
        "class",
        "function",
        "method",
        "api_endpoint",
        "database_table",
        "database_schema",
        "configuration",
        "test",
        "adr",
        "rationale",
        "dependency"
      ],
      "title": "CodeNodeKind",
      "type": "string"
    },
    "CodeSourceLocation": {
      "additionalProperties": false,
      "properties": {
        "end_column": {
          "default": 0,
          "maximum": 10000000,
          "minimum": 0,
          "title": "End Column",
          "type": "integer"
        },
        "end_line": {
          "maximum": 10000000,
          "minimum": 1,
          "title": "End Line",
          "type": "integer"
        },
        "extensions": {
          "additionalProperties": true,
          "title": "Extensions",
          "type": "object"
        },
        "id_scheme_version": {
          "default": "1",
          "title": "Id Scheme Version",
          "type": "string"
        },
        "schema_name": {
          "const": "CodeSourceLocationV1",
          "default": "CodeSourceLocationV1",
          "title": "Schema Name",
          "type": "string"
        },
        "schema_version": {
          "default": "1.4.0",
          "title": "Schema Version",
          "type": "string"
        },
        "start_column": {
          "default": 0,
          "maximum": 10000000,
          "minimum": 0,
          "title": "Start Column",
          "type": "integer"
        },
        "start_line": {
          "maximum": 10000000,
          "minimum": 1,
          "title": "Start Line",
          "type": "integer"
        }
      },
      "required": [
        "start_line",
        "end_line"
      ],
      "title": "CodeSourceLocation",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "community_id": {
      "anyOf": [
        {
          "maximum": 1000000,
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Community Id"
    },
    "content_fingerprint": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Content Fingerprint",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "extractor": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Extractor",
      "type": "string"
    },
    "extractor_version": {
      "maxLength": 128,
      "minLength": 1,
      "title": "Extractor Version",
      "type": "string"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "is_bridge": {
      "default": false,
      "title": "Is Bridge",
      "type": "boolean"
    },
    "is_god": {
      "default": false,
      "title": "Is God",
      "type": "boolean"
    },
    "kind": {
      "$ref": "#/$defs/CodeNodeKind"
    },
    "label": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Label",
      "type": "string"
    },
    "location": {
      "anyOf": [
        {
          "$ref": "#/$defs/CodeSourceLocation"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "metadata": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Metadata",
      "type": "object"
    },
    "node_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Node Id",
      "type": "string"
    },
    "path": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Path"
    },
    "qualified_name": {
      "default": "",
      "maxLength": 1024,
      "title": "Qualified Name",
      "type": "string"
    },
    "schema_name": {
      "const": "CodeNodeV1",
      "default": "CodeNodeV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "node_id",
    "kind",
    "label",
    "content_fingerprint",
    "extractor",
    "extractor_version"
  ],
  "title": "CodeNode",
  "type": "object"
}
