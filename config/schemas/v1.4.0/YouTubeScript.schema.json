{
  "$defs": {
    "YouTubeLineKind": {
      "enum": [
        "factual",
        "inference",
        "editorial"
      ],
      "title": "YouTubeLineKind",
      "type": "string"
    },
    "YouTubeScriptBeat": {
      "additionalProperties": false,
      "properties": {
        "beat_id": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Beat Id",
          "type": "string"
        },
        "fact_ids": {
          "default": [],
          "items": {
            "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
            "type": "string"
          },
          "title": "Fact Ids",
          "type": "array"
        },
        "heading": {
          "maxLength": 4096,
          "minLength": 1,
          "title": "Heading",
          "type": "string"
        },
        "line_kind": {
          "$ref": "#/$defs/YouTubeLineKind"
        },
        "text": {
          "maxLength": 4096,
          "minLength": 1,
          "title": "Text",
          "type": "string"
        }
      },
      "required": [
        "beat_id",
        "heading",
        "text",
        "line_kind"
      ],
      "title": "YouTubeScriptBeat",
      "type": "object"
    },
    "YouTubeScriptMode": {
      "enum": [
        "anchor",
        "verbatim"
      ],
      "title": "YouTubeScriptMode",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "beats": {
      "items": {
        "$ref": "#/$defs/YouTubeScriptBeat"
      },
      "minItems": 2,
      "title": "Beats",
      "type": "array"
    },
    "cta": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Cta",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "hook": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Hook",
      "type": "string"
    },
    "hook_fact_ids": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Hook Fact Ids",
      "type": "array"
    },
    "hook_kind": {
      "$ref": "#/$defs/YouTubeLineKind"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "mode": {
      "$ref": "#/$defs/YouTubeScriptMode"
    },
    "needs_review": {
      "default": true,
      "title": "Needs Review",
      "type": "boolean"
    },
    "project_id": {
      "pattern": "^ytp_[a-z0-9_]{2,120}$",
      "title": "Project Id",
      "type": "string"
    },
    "schema_name": {
      "const": "YouTubeScriptV1",
      "default": "YouTubeScriptV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "script_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Script Id",
      "type": "string"
    },
    "source_fact_ids": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Source Fact Ids",
      "type": "array"
    },
    "state": {
      "const": "draft",
      "default": "draft",
      "title": "State",
      "type": "string"
    }
  },
  "required": [
    "script_id",
    "project_id",
    "mode",
    "hook",
    "hook_kind",
    "beats",
    "cta"
  ],
  "title": "YouTubeScript",
  "type": "object"
}
