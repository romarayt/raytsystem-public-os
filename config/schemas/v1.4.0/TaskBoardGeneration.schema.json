{
  "additionalProperties": false,
  "properties": {
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "event_count": {
      "default": 0,
      "maximum": 10000,
      "minimum": 0,
      "title": "Event Count",
      "type": "integer"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "generation_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Generation Id",
      "type": "string"
    },
    "head_event_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Head Event Id"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "latest_event_ids": {
      "patternProperties": {
        "^[a-z][a-z0-9_:.@/-]{1,255}$": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        }
      },
      "title": "Latest Event Ids",
      "type": "object"
    },
    "parent_generation_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Parent Generation Id"
    },
    "parent_generation_sha256": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Parent Generation Sha256"
    },
    "schema_name": {
      "const": "TaskBoardGenerationV1",
      "default": "TaskBoardGenerationV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "task_hashes": {
      "patternProperties": {
        "^[a-z][a-z0-9_:.@/-]{1,255}$": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        }
      },
      "title": "Task Hashes",
      "type": "object"
    }
  },
  "required": [
    "generation_id",
    "created_at"
  ],
  "title": "TaskBoardGeneration",
  "type": "object"
}
