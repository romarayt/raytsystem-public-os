{
  "$defs": {
    "EvalRunState": {
      "enum": [
        "planned",
        "running",
        "passed",
        "failed",
        "blocked",
        "cancelled"
      ],
      "title": "EvalRunState",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "baseline_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Baseline Id"
    },
    "completed_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Completed At"
    },
    "deterministic_score_ids": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Deterministic Score Ids",
      "type": "array"
    },
    "eval_run_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Eval Run Id",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "judge_score_ids": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Judge Score Ids",
      "type": "array"
    },
    "result_ids": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Result Ids",
      "type": "array"
    },
    "schema_name": {
      "const": "EvalRunV1",
      "default": "EvalRunV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "started_at": {
      "format": "date-time",
      "title": "Started At",
      "type": "string"
    },
    "state": {
      "$ref": "#/$defs/EvalRunState"
    },
    "suite_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Suite Id",
      "type": "string"
    },
    "suite_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Suite Sha256",
      "type": "string"
    },
    "target_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Target Id",
      "type": "string"
    },
    "workspace_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Workspace Id",
      "type": "string"
    }
  },
  "required": [
    "eval_run_id",
    "suite_id",
    "suite_sha256",
    "target_id",
    "state",
    "workspace_id",
    "started_at"
  ],
  "title": "EvalRun",
  "type": "object"
}
