{
  "additionalProperties": false,
  "properties": {
    "cost_budget": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Cost Budget"
    },
    "employee_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Employee Id",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "graph_scope": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Graph Scope",
      "type": "array"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "knowledge_scope": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Knowledge Scope",
      "type": "array"
    },
    "model": {
      "anyOf": [
        {
          "maxLength": 4096,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Model"
    },
    "network_access": {
      "default": "none",
      "enum": [
        "none",
        "allowlist",
        "unrestricted"
      ],
      "title": "Network Access",
      "type": "string"
    },
    "network_destinations": {
      "default": [],
      "items": {
        "maxLength": 4096,
        "minLength": 1,
        "type": "string"
      },
      "title": "Network Destinations",
      "type": "array"
    },
    "plan_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Plan Id",
      "type": "string"
    },
    "policy_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Policy Sha256",
      "type": "string"
    },
    "potential_side_effects": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Potential Side Effects",
      "type": "array"
    },
    "provider": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Provider"
    },
    "read_roots": {
      "default": [],
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "Read Roots",
      "type": "array"
    },
    "requested_secrets": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Requested Secrets",
      "type": "array"
    },
    "requested_tools": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Requested Tools",
      "type": "array"
    },
    "runtime_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Runtime Id",
      "type": "string"
    },
    "schema_name": {
      "const": "ExecutionPlanV1",
      "default": "ExecutionPlanV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "task_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Task Id",
      "type": "string"
    },
    "task_revision": {
      "minimum": 1,
      "title": "Task Revision",
      "type": "integer"
    },
    "token_budget": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Token Budget"
    },
    "workspace_mode": {
      "enum": [
        "none",
        "read_only",
        "staging_only",
        "isolated"
      ],
      "title": "Workspace Mode",
      "type": "string"
    },
    "write_roots": {
      "default": [],
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "Write Roots",
      "type": "array"
    }
  },
  "required": [
    "plan_id",
    "employee_id",
    "task_id",
    "task_revision",
    "runtime_id",
    "workspace_mode",
    "policy_sha256"
  ],
  "title": "ExecutionPlan",
  "type": "object"
}
