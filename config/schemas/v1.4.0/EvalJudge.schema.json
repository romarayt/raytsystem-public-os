    "kind": {
      "const": "llm",
      "default": "llm",
      "title": "Kind",
      "type": "string"
    },
    "model": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Model",
      "type": "string"
    },
    "optional": {
      "default": true,
      "title": "Optional",
      "type": "boolean"
    },
    "provider": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
