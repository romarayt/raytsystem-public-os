{
  "$defs": {
    "McpServerState": {
      "enum": [
        "discovered",
        "quarantined",
        "validated",
        "approved",
        "enabled",
        "disabled",
        "degraded",
        "blocked"
      ],
      "title": "McpServerState",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "approval_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Approval Id"
    },
    "approved_by": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Approved By"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "definition_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Definition Sha256",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "previous_revision_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Previous Revision Id"
    },
    "revision_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Revision Id",
      "type": "string"
    },
    "schema_name": {
      "const": "McpServerRevisionV1",
      "default": "McpServerRevisionV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "server_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Server Id",
      "type": "string"
    },
    "state": {
      "$ref": "#/$defs/McpServerState"
    }
  },
  "required": [
    "revision_id",
    "server_id",
    "definition_sha256",
    "state",
    "created_at"
  ],
  "title": "McpServerRevision",
  "type": "object"
}
