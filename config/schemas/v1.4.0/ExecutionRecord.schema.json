{
  "additionalProperties": false,
  "properties": {
    "approval_ids": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Approval Ids",
      "type": "array"
    },
    "cost_budget": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Cost Budget"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "execution_record_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Execution Record Id",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "graph_snapshot_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Graph Snapshot Id"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "instruction_hashes": {
      "patternProperties": {
        "^[a-z][a-z0-9_:.@/-]{1,255}$": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        }
      },
      "title": "Instruction Hashes",
      "type": "object"
    },
    "knowledge_generation_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Knowledge Generation Id"
    },
    "manifest_path": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Manifest Path"
    },
    "model": {
      "anyOf": [
        {
          "maxLength": 4096,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Model"
    },
    "policy_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Policy Sha256",
      "type": "string"
    },
    "repository_snapshot_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Repository Snapshot Sha256",
      "type": "string"
    },
    "result_sha256": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Result Sha256"
    },
    "run_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Run Id",
      "type": "string"
    },
    "runtime_configuration_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Runtime Configuration Sha256",
      "type": "string"
    },
    "runtime_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Runtime Id",
      "type": "string"
    },
    "schema_name": {
      "const": "ExecutionRecordV1",
      "default": "ExecutionRecordV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "side_effect_ids": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Side Effect Ids",
      "type": "array"
    },
    "skill_hashes": {
      "patternProperties": {
        "^[a-z][a-z0-9_:.@/-]{1,255}$": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        }
      },
      "title": "Skill Hashes",
      "type": "object"
    },
    "task_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Task Id"
    },
    "task_revision": {
      "anyOf": [
        {
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Task Revision"
    },
    "token_budget": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Token Budget"
    },
    "toolset_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Toolset Sha256",
      "type": "string"
    },
    "trace_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Trace Id"
    }
  },
  "required": [
    "execution_record_id",
    "run_id",
    "repository_snapshot_sha256",
    "instruction_hashes",
    "skill_hashes",
    "policy_sha256",
    "toolset_sha256",
    "runtime_configuration_sha256",
    "runtime_id",
    "created_at"
  ],
  "title": "ExecutionRecord",
  "type": "object"
}
