{
  "$defs": {
    "ExecutionSessionStatus": {
      "enum": [
        "active",
        "paused",
        "completed",
        "incompatible",
        "error"
      ],
      "title": "ExecutionSessionStatus",
      "type": "string"
    },
    "ExecutionUsage": {
      "additionalProperties": false,
      "properties": {
        "actual_cost_micros": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Actual Cost Micros"
        },
        "cached_tokens": {
          "default": 0,
          "minimum": 0,
          "title": "Cached Tokens",
          "type": "integer"
        },
        "estimated_cost_micros": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Estimated Cost Micros"
        },
        "extensions": {
          "additionalProperties": true,
          "title": "Extensions",
          "type": "object"
        },
        "id_scheme_version": {
          "default": "1",
          "title": "Id Scheme Version",
          "type": "string"
        },
        "input_tokens": {
          "default": 0,
          "minimum": 0,
          "title": "Input Tokens",
          "type": "integer"
        },
        "output_tokens": {
          "default": 0,
          "minimum": 0,
          "title": "Output Tokens",
          "type": "integer"
        },
        "schema_name": {
          "const": "ExecutionUsageV1",
          "default": "ExecutionUsageV1",
          "title": "Schema Name",
          "type": "string"
        },
        "schema_version": {
          "default": "1.4.0",
          "title": "Schema Version",
          "type": "string"
        }
      },
      "title": "ExecutionUsage",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "compatibility_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Compatibility Sha256",
      "type": "string"
    },
    "context_snapshot_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Context Snapshot Sha256",
      "type": "string"
    },
    "employee_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Employee Id",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "graph_snapshot_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Graph Snapshot Id",
      "type": "string"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "incompatibility_reason": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Incompatibility Reason"
    },
    "last_resumed_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Last Resumed At"
    },
    "model": {
      "anyOf": [
        {
          "maxLength": 256,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Model"
    },
    "previous_run_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Previous Run Id"
    },
    "provider": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Provider",
      "type": "string"
    },
    "provider_session_id": {
      "anyOf": [
        {
          "maxLength": 512,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Provider Session Id"
    },
    "runtime_adapter_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Runtime Adapter Id",
      "type": "string"
    },
    "schema_name": {
      "const": "ExecutionSessionV1",
      "default": "ExecutionSessionV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "session_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Session Id",
      "type": "string"
    },
    "started_at": {
      "format": "date-time",
      "title": "Started At",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/ExecutionSessionStatus",
      "default": "active"
    },
    "task_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Task Id",
      "type": "string"
    },
    "usage_totals": {
      "$ref": "#/$defs/ExecutionUsage"
    },
    "workspace_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Workspace Id",
      "type": "string"
    }
  },
  "required": [
    "session_id",
    "runtime_adapter_id",
    "provider",
    "task_id",
    "employee_id",
    "workspace_id",
    "graph_snapshot_id",
    "context_snapshot_sha256",
    "compatibility_sha256",
    "started_at"
  ],
  "title": "ExecutionSession",
  "type": "object"
}
