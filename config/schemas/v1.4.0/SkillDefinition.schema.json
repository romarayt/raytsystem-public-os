{
  "$defs": {
    "Sensitivity": {
      "enum": [
        "public",
        "internal",
        "confidential",
        "restricted",
        "secret"
      ],
      "title": "Sensitivity",
      "type": "string"
    },
    "TrustClass": {
      "enum": [
        "primary",
        "official",
        "research",
        "user",
        "community",
        "generated",
        "untrusted"
      ],
      "title": "TrustClass",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "description": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Description",
      "type": "string"
    },
    "enabled": {
      "default": true,
      "title": "Enabled",
      "type": "boolean"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "name": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Name",
      "type": "string"
    },
    "pack_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Pack Id",
      "type": "string"
    },
    "permissions": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Permissions",
      "type": "array"
    },
    "schema_name": {
      "const": "SkillDefinitionV1",
      "default": "SkillDefinitionV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    },
    "sensitivity": {
      "$ref": "#/$defs/Sensitivity",
      "default": "internal"
    },
    "skill_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Skill Id",
      "type": "string"
    },
    "source_path": {
      "minLength": 1,
      "title": "Source Path",
      "type": "string"
    },
    "source_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Source Sha256",
      "type": "string"
    },
    "test_status": {
      "default": "pending",
      "enum": [
        "pass",
        "pending",
        "unavailable"
      ],
      "title": "Test Status",
      "type": "string"
    },
    "trust_class": {
      "$ref": "#/$defs/TrustClass"
    },
    "version": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Version",
      "type": "string"
    }
  },
  "required": [
    "skill_id",
    "name",
    "description",
    "version",
    "source_path",
    "source_sha256",
    "pack_id",
    "trust_class"
  ],
  "title": "SkillDefinition",
  "type": "object"
}
