      "maxLength": 4096,
      "minLength": 1,
      "title": "Authentication Tag",
      "type": "string"
    },
    "blob_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Blob Id",
      "type": "string"
    },
    "ciphertext": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Ciphertext",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "encrypted_data_key": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Encrypted Data Key",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "key_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Key Id",
      "type": "string"
    },
    "key_provider_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Key Provider Id",
      "type": "string"
    },
    "nonce": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Nonce",
      "type": "string"
    },
    "plaintext_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Plaintext Sha256",
      "type": "string"
    },
    "schema_name": {
      "const": "EncryptedBlobV1",
      "default": "EncryptedBlobV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.4.0",
      "title": "Schema Version",
      "type": "string"
    }
