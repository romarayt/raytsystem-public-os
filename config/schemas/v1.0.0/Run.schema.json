{
  "$defs": {
    "ComponentRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Artifact Sha256"
        },
        "config_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Config Sha256",
          "type": "string"
        },
        "name": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Name",
          "type": "string"
        },
        "version": {
          "maxLength": 4096,
          "minLength": 1,
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "name",
        "version",
        "config_sha256"
      ],
      "title": "ComponentRef",
      "type": "object"
    },
    "ErrorCategory": {
      "enum": [
        "transient",
        "validation",
        "policy",
        "data",
        "dependency",
        "terminal"
      ],
      "title": "ErrorCategory",
      "type": "string"
    },
    "ErrorRecord": {
      "additionalProperties": false,
      "properties": {
        "category": {
          "$ref": "#/$defs/ErrorCategory"
        },
        "code": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Code",
          "type": "string"
        },
        "details": {
          "additionalProperties": true,
          "title": "Details",
          "type": "object"
        },
        "message": {
          "maxLength": 4096,
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "retryable": {
          "default": false,
          "title": "Retryable",
          "type": "boolean"
        }
      },
      "required": [
        "category",
        "code",
        "message"
      ],
      "title": "ErrorRecord",
      "type": "object"
    },
    "OperationFingerprint": {
      "additionalProperties": false,
      "properties": {
        "components": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ComponentRef"
          },
          "title": "Components",
          "type": "array"
        },
        "extensions": {
          "additionalProperties": true,
          "title": "Extensions",
          "type": "object"
        },
        "id_scheme_version": {
          "default": "1",
          "title": "Id Scheme Version",
          "type": "string"
        },
        "input_hashes": {
          "default": [],
          "items": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "title": "Input Hashes",
          "type": "array"
        },
        "model_id": {
          "anyOf": [
            {
              "maxLength": 4096,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Model Id"
        },
        "operation_type": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Operation Type",
          "type": "string"
        },
        "pipeline_version": {
          "maxLength": 4096,
          "minLength": 1,
          "title": "Pipeline Version",
          "type": "string"
        },
        "prompt_or_skill_sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Prompt Or Skill Sha256"
        },
        "relevant_config_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Relevant Config Sha256",
          "type": "string"
        },
        "schema_name": {
          "const": "OperationFingerprintV1",
          "default": "OperationFingerprintV1",
          "title": "Schema Name",
          "type": "string"
        },
        "schema_registry_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Schema Registry Sha256",
          "type": "string"
        },
        "schema_version": {
          "default": "1.0.0",
          "title": "Schema Version",
          "type": "string"
        }
      },
      "required": [
        "operation_type",
        "schema_registry_sha256",
        "pipeline_version",
        "relevant_config_sha256"
      ],
      "title": "OperationFingerprint",
      "type": "object"
    },
    "RecordRef": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Kind",
          "type": "string"
        },
        "object_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Object Sha256",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "id",
        "object_sha256"
      ],
      "title": "RecordRef",
      "type": "object"
    },
    "RunState": {
      "enum": [
        "queued",
        "running",
        "staging",
        "validating",
        "awaiting_review",
        "awaiting_approval",
        "promoting",
        "promoted",
        "reconciling",
        "succeeded",
        "retryable_failed",
        "terminal_failed",
        "quarantined",
        "cancelled"
      ],
      "title": "RunState",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "egress_destination": {
      "anyOf": [
        {
          "maxLength": 4096,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Egress Destination"
    },
    "error": {
      "anyOf": [
        {
          "$ref": "#/$defs/ErrorRecord"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "fingerprint": {
      "$ref": "#/$defs/OperationFingerprint"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "input_refs": {
      "default": [],
      "items": {
        "$ref": "#/$defs/RecordRef"
      },
      "title": "Input Refs",
      "type": "array"
    },
    "last_completed_gate": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Last Completed Gate"
    },
    "operation_key": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Operation Key",
      "type": "string"
    },
    "operation_type": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Operation Type",
      "type": "string"
    },
    "partition_key": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Partition Key",
      "type": "string"
    },
    "permission_mode": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Permission Mode",
      "type": "string"
    },
    "result_refs": {
      "default": [],
      "items": {
        "$ref": "#/$defs/RecordRef"
      },
      "title": "Result Refs",
      "type": "array"
    },
    "retry_count": {
      "default": 0,
      "minimum": 0,
      "title": "Retry Count",
      "type": "integer"
    },
    "run_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Run Id",
      "type": "string"
    },
    "schema_name": {
      "const": "RunV1",
      "default": "RunV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "staging_path": {
      "minLength": 1,
      "title": "Staging Path",
      "type": "string"
    },
    "state": {
      "$ref": "#/$defs/RunState",
      "default": "queued"
    },
    "surface": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Surface",
      "type": "string"
    },
    "updated_at": {
      "format": "date-time",
      "title": "Updated At",
      "type": "string"
    }
  },
  "required": [
    "run_id",
    "operation_type",
    "operation_key",
    "partition_key",
    "fingerprint",
    "surface",
    "permission_mode",
    "created_at",
    "updated_at",
    "staging_path"
  ],
  "title": "Run",
  "type": "object"
}
