{
  "additionalProperties": false,
  "properties": {
    "committed_at": {
      "format": "date-time",
      "title": "Committed At",
      "type": "string"
    },
    "event_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Event Id",
      "type": "string"
    },
    "event_type": {
      "default": "promotion",
      "enum": [
        "promotion",
        "compensating_promotion"
      ],
      "title": "Event Type",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "new_generation_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "New Generation Id",
      "type": "string"
    },
    "operation_key": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Operation Key",
      "type": "string"
    },
    "parent_generation_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Parent Generation Id",
      "type": "string"
    },
    "previous_event_sha256": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Previous Event Sha256"
    },
    "run_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Run Id",
      "type": "string"
    },
    "schema_name": {
      "const": "PromotionEventV1",
      "default": "PromotionEventV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "txn_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Txn Id",
      "type": "string"
    }
  },
  "required": [
    "event_id",
    "txn_id",
    "run_id",
    "operation_key",
    "parent_generation_id",
    "new_generation_id",
    "committed_at"
  ],
  "title": "PromotionEvent",
  "type": "object"
}
