{
  "$defs": {
    "Origin": {
      "additionalProperties": false,
      "properties": {
        "extensions": {
          "additionalProperties": true,
          "title": "Extensions",
          "type": "object"
        },
        "id_scheme_version": {
          "default": "1",
          "title": "Id Scheme Version",
          "type": "string"
        },
        "kind": {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "title": "Kind",
          "type": "string"
        },
        "locator": {
          "anyOf": [
            {
              "maxLength": 4096,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Locator"
        },
        "locator_sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Locator Sha256"
        },
        "schema_name": {
          "const": "OriginV1",
          "default": "OriginV1",
          "title": "Schema Name",
          "type": "string"
        },
        "schema_version": {
          "default": "1.0.0",
          "title": "Schema Version",
          "type": "string"
        }
      },
      "required": [
        "kind"
      ],
      "title": "Origin",
      "type": "object"
    },
    "Sensitivity": {
      "enum": [
        "public",
        "internal",
        "confidential",
        "restricted",
        "secret"
      ],
      "title": "Sensitivity",
      "type": "string"
    },
    "TrustClass": {
      "enum": [
        "primary",
        "official",
        "research",
        "user",
        "community",
        "generated",
        "untrusted"
      ],
      "title": "TrustClass",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "display_name": {
      "anyOf": [
        {
          "maxLength": 4096,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Display Name"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "identity_key_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Identity Key Sha256",
      "type": "string"
    },
    "identity_scheme": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Identity Scheme",
      "type": "string"
    },
    "origin": {
      "$ref": "#/$defs/Origin"
    },
    "rights": {
      "default": "unknown",
      "maxLength": 4096,
      "minLength": 1,
      "title": "Rights",
      "type": "string"
    },
    "schema_name": {
      "const": "SourceV1",
      "default": "SourceV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "sensitivity": {
      "$ref": "#/$defs/Sensitivity",
      "default": "internal"
    },
    "source_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Source Id",
      "type": "string"
    },
    "source_type": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Source Type",
      "type": "string"
    },
    "trust_class": {
      "$ref": "#/$defs/TrustClass",
      "default": "untrusted"
    }
  },
  "required": [
    "source_id",
    "identity_scheme",
    "identity_key_sha256",
    "origin",
    "source_type",
    "created_at"
  ],
  "title": "Source",
  "type": "object"
}
