{
  "$defs": {
    "RuntimeAdapterState": {
      "enum": [
        "disabled",
        "available",
        "configured",
        "degraded"
      ],
      "title": "RuntimeAdapterState",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "adapter_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Adapter Id",
      "type": "string"
    },
    "capabilities": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Capabilities",
      "type": "array"
    },
    "egress_destination": {
      "anyOf": [
        {
          "maxLength": 4096,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Egress Destination"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "isolation_mode": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Isolation Mode",
      "type": "string"
    },
    "name": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Name",
      "type": "string"
    },
    "reason": {
      "anyOf": [
        {
          "maxLength": 4096,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Reason"
    },
    "schema_name": {
      "const": "RuntimeAdapterDefinitionV1",
      "default": "RuntimeAdapterDefinitionV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.3.0",
      "title": "Schema Version",
      "type": "string"
    },
    "state": {
      "$ref": "#/$defs/RuntimeAdapterState"
    },
    "version": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Version",
      "type": "string"
    }
  },
  "required": [
    "adapter_id",
    "name",
    "version",
    "state",
    "isolation_mode"
  ],
  "title": "RuntimeAdapterDefinition",
  "type": "object"
}
