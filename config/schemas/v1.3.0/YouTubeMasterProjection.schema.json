{
  "additionalProperties": false,
  "properties": {
    "content_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Content Sha256",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "generated_at": {
      "format": "date-time",
      "title": "Generated At",
      "type": "string"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "master_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Master Id",
      "type": "string"
    },
    "path": {
      "minLength": 1,
      "title": "Path",
      "type": "string"
    },
    "project_id": {
      "pattern": "^ytp_[a-z0-9_]{2,120}$",
      "title": "Project Id",
      "type": "string"
    },
    "schema_name": {
      "const": "YouTubeMasterProjectionV1",
      "default": "YouTubeMasterProjectionV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.3.0",
      "title": "Schema Version",
      "type": "string"
    },
    "source_stage_hashes": {
      "additionalProperties": {
        "pattern": "^[0-9a-f]{64}$",
        "type": "string"
      },
      "title": "Source Stage Hashes",
      "type": "object"
    },
    "state": {
      "const": "draft",
      "default": "draft",
      "title": "State",
      "type": "string"
    },
    "synthetic_fixture": {
      "const": true,
      "default": true,
      "title": "Synthetic Fixture",
      "type": "boolean"
    }
  },
  "required": [
    "master_id",
    "project_id",
    "path",
    "content_sha256",
    "source_stage_hashes",
    "generated_at"
  ],
  "title": "YouTubeMasterProjection",
  "type": "object"
}
