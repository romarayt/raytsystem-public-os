{
  "$defs": {
    "Sensitivity": {
      "enum": [
        "public",
        "internal",
        "confidential",
        "restricted",
        "secret"
      ],
      "title": "Sensitivity",
      "type": "string"
    },
    "TaskPriority": {
      "enum": [
        "low",
        "normal",
        "high",
        "urgent"
      ],
      "title": "TaskPriority",
      "type": "string"
    },
    "TaskStatus": {
      "enum": [
        "inbox",
        "planned",
        "ready",
        "running",
        "review",
        "blocked",
        "done",
        "cancelled"
      ],
      "title": "TaskStatus",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "artifact_ids": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Artifact Ids",
      "type": "array"
    },
    "assignee_ids": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Assignee Ids",
      "type": "array"
    },
    "blocked_reason": {
      "anyOf": [
        {
          "maxLength": 4096,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Blocked Reason"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "created_by": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Created By",
      "type": "string"
    },
    "dependency_ids": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Dependency Ids",
      "type": "array"
    },
    "description": {
      "default": "",
      "maxLength": 32768,
      "title": "Description",
      "type": "string"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "mission_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Mission Id"
    },
    "priority": {
      "$ref": "#/$defs/TaskPriority",
      "default": "normal"
    },
    "project_id": {
      "default": "project_default",
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Project Id",
      "type": "string"
    },
    "revision": {
      "default": 1,
      "minimum": 1,
      "title": "Revision",
      "type": "integer"
    },
    "schema_name": {
      "const": "AgentTaskV1",
      "default": "AgentTaskV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.3.0",
      "title": "Schema Version",
      "type": "string"
    },
    "sensitivity": {
      "$ref": "#/$defs/Sensitivity",
      "default": "internal"
    },
    "skill_ids": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Skill Ids",
      "type": "array"
    },
    "status": {
      "$ref": "#/$defs/TaskStatus",
      "default": "inbox"
    },
    "tags": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Tags",
      "type": "array"
    },
    "task_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Task Id",
      "type": "string"
    },
    "title": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Title",
      "type": "string"
    },
    "updated_at": {
      "format": "date-time",
      "title": "Updated At",
      "type": "string"
    }
  },
  "required": [
    "task_id",
    "title",
    "created_by",
    "created_at",
    "updated_at"
  ],
  "title": "AgentTask",
  "type": "object"
}
