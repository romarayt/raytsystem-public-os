{
  "additionalProperties": false,
  "properties": {
    "agent_definition_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Agent Definition Sha256",
      "type": "string"
    },
    "agent_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Agent Id",
      "type": "string"
    },
    "approval_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Approval Id"
    },
    "context_snapshot_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Context Snapshot Sha256",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "data_class": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Data Class",
      "type": "string"
    },
    "egress_destination": {
      "anyOf": [
        {
          "maxLength": 4096,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Egress Destination"
    },
    "extensions": {
      "additionalProperties": true,
      "title": "Extensions",
      "type": "object"
    },
    "granted_capabilities": {
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Granted Capabilities",
      "type": "array"
    },
    "id_scheme_version": {
      "default": "1",
      "title": "Id Scheme Version",
      "type": "string"
    },
    "idempotency_key": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Idempotency Key",
      "type": "string"
    },
    "invocation_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Invocation Id",
      "type": "string"
    },
    "policy_decision_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Policy Decision Id",
      "type": "string"
    },
    "policy_decision_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Policy Decision Sha256",
      "type": "string"
    },
    "requested_capabilities": {
      "items": {
        "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
        "type": "string"
      },
      "title": "Requested Capabilities",
      "type": "array"
    },
    "runtime_adapter_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Runtime Adapter Sha256",
      "type": "string"
    },
    "schema_name": {
      "const": "AgentInvocationV1",
      "default": "AgentInvocationV1",
      "title": "Schema Name",
      "type": "string"
    },
    "schema_version": {
      "default": "1.3.0",
      "title": "Schema Version",
      "type": "string"
    },
    "skill_definition_hashes": {
      "patternProperties": {
        "^[a-z][a-z0-9_:.@/-]{1,255}$": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        }
      },
      "title": "Skill Definition Hashes",
      "type": "object"
    },
    "task_id": {
      "pattern": "^[a-z][a-z0-9_:.@/-]{1,255}$",
      "title": "Task Id",
      "type": "string"
    }
  },
  "required": [
    "invocation_id",
    "task_id",
    "agent_id",
    "agent_definition_sha256",
    "runtime_adapter_sha256",
    "context_snapshot_sha256",
    "skill_definition_hashes",
    "policy_decision_id",
    "policy_decision_sha256",
    "idempotency_key",
    "requested_capabilities",
    "granted_capabilities",
    "data_class",
    "created_at"
  ],
  "title": "AgentInvocation",
  "type": "object"
}
